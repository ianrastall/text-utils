---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Dictation" description="Dictate into your microphone and copy the transcript.">
  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Dictation</h1>
        <p>Speak, edit the transcript, then copy it into Reddit, Facebook, YouTube, or anywhere else.</p>
      </div>
      <a class="button" href="/">Back</a>
    </div>
    <section class="panel">
      <div class="control-row">
        <button id="start" class="primary" type="button" disabled>Start</button>
        <button id="stop" type="button" disabled>Stop</button>
        <button id="copy" type="button">Copy</button>
        <button id="clear" type="button">Clear</button>
        <span class="record-dot" id="record-dot" aria-hidden="true"></span>
        <span id="listen-state">Idle</span>
      </div>
      <div class="control-row">
        <div class="field">
          <label for="language">Language</label>
          <select id="language">
            <option value="en-US">English (US)</option>
            <option value="en-GB">English (UK)</option>
            <option value="en-CA">English (Canada)</option>
            <option value="en-AU">English (Australia)</option>
          </select>
        </div>
        <button id="newline" type="button">New Line</button>
        <button id="paragraph" type="button">New Paragraph</button>
      </div>
      <div class="field">
        <label for="transcript">Transcript</label>
        <textarea id="transcript" placeholder="Your dictated text will appear here"></textarea>
      </div>
      <div class="status-line">
        <span id="status" class="status-good">Ready</span>
        <span id="stats">0 characters, 0 words</span>
      </div>
    </section>
  </main>
  <script>
    const SpeechRecognitionConstructor = window.SpeechRecognition || window.webkitSpeechRecognition;
    const supported = typeof SpeechRecognitionConstructor === 'function';
    const start = document.getElementById('start') as HTMLButtonElement;
    const stop = document.getElementById('stop') as HTMLButtonElement;
    const copy = document.getElementById('copy') as HTMLButtonElement;
    const clear = document.getElementById('clear') as HTMLButtonElement;
    const newline = document.getElementById('newline') as HTMLButtonElement;
    const paragraph = document.getElementById('paragraph') as HTMLButtonElement;
    const transcript = document.getElementById('transcript') as HTMLTextAreaElement;
    const language = document.getElementById('language') as HTMLSelectElement;
    const status = document.getElementById('status') as HTMLSpanElement;
    const stats = document.getElementById('stats') as HTMLSpanElement;
    const state = document.getElementById('listen-state') as HTMLSpanElement;
    const dot = document.getElementById('record-dot') as HTMLSpanElement;

    let recognition: SpeechRecognition | null = null;
    let finalText = '';

    function updateStats() {
      const words = transcript.value.trim().match(/\S+/g)?.length ?? 0;
      stats.textContent = `${transcript.value.length} characters, ${words} words`;
    }

    function appendText(base: string, next: string) {
      const cleaned = next.trim();
      if (!cleaned) return base;
      if (!base) return cleaned;
      return `${base.trimEnd()} ${cleaned}`;
    }

    function setListening(listening: boolean) {
      start.disabled = listening || !supported;
      stop.disabled = !listening;
      language.disabled = listening;
      state.textContent = listening ? 'Listening' : 'Idle';
      dot.classList.toggle('active', listening);
    }

    function insert(text: string) {
      const startAt = transcript.selectionStart ?? transcript.value.length;
      const endAt = transcript.selectionEnd ?? transcript.value.length;
      transcript.value = transcript.value.slice(0, startAt) + text + transcript.value.slice(endAt);
      transcript.focus();
      transcript.setSelectionRange(startAt + text.length, startAt + text.length);
      finalText = transcript.value;
      updateStats();
    }

    start.addEventListener('click', () => {
      if (!supported) return;
      finalText = transcript.value;
      if (!SpeechRecognitionConstructor) return;

      recognition = new SpeechRecognitionConstructor();
      recognition.lang = language.value;
      recognition.continuous = true;
      recognition.interimResults = true;
      recognition.addEventListener('start', () => {
        setListening(true);
        status.textContent = 'Listening';
      });
      recognition.addEventListener('result', (event: SpeechRecognitionEvent) => {
        let interim = '';
        for (let index = event.resultIndex; index < event.results.length; index += 1) {
          const result = event.results[index];
          const text = result[0]?.transcript ?? '';
          if (result.isFinal) finalText = appendText(finalText, text);
          else interim = appendText(interim, text);
        }
        transcript.value = interim ? appendText(finalText, interim) : finalText;
        updateStats();
      });
      recognition.addEventListener('end', () => {
        finalText = transcript.value;
        setListening(false);
        status.textContent = 'Ready';
      });
      recognition.addEventListener('error', () => {
        status.textContent = 'Microphone or speech recognition error';
        status.className = 'status-bad';
      });
      recognition.start();
    });

    stop.addEventListener('click', () => recognition?.stop());
    copy.addEventListener('click', async () => {
      await navigator.clipboard.writeText(transcript.value);
      status.textContent = 'Copied';
      status.className = 'status-good';
    });
    clear.addEventListener('click', () => {
      transcript.value = '';
      finalText = '';
      updateStats();
      transcript.focus();
    });
    newline.addEventListener('click', () => insert('\n'));
    paragraph.addEventListener('click', () => insert('\n\n'));
    transcript.addEventListener('input', () => {
      finalText = transcript.value;
      updateStats();
    });

    if (!supported) {
      status.textContent = 'Speech recognition is not available in this browser';
      status.className = 'status-bad';
      start.disabled = true;
    } else {
      start.disabled = false;
    }
    updateStats();
  </script>
</BaseLayout>
