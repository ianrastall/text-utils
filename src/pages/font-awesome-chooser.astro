      ['place-of-worship','s',['map']],

      // === BRANDS / SOCIAL ===
      ['facebook','b',['social']], ['facebook-f','b',['social']],
      ['x-twitter','b',['social']], ['twitter','b',['social']],
      ['instagram','b',['social']], ['linkedin','b',['social']], ['linkedin-in','b',['social']],
      ['youtube','b',['social']], ['github','b',['social']], ['gitlab','b',['social']],
      ['bitbucket','b',['social']], ['discord','b',['social']], ['slack','b',['social']],
      ['whatsapp','b',['social','comm']], ['telegram','b',['social','comm']],
      ['snapchat','b',['social']], ['tiktok','b',['social']], ['pinterest','b',['social']],
      ['reddit','b',['social']], ['reddit-alien','b',['social']], ['twitch','b',['social']],
      ['spotify','b',['social','media']], ['apple','b',['social','sci']],
      ['google','b',['social']], ['google-play','b',['social']],
      ['microsoft','b',['social','sci']], ['windows','b',['social','sci']],
      ['android','b',['social','sci']], ['amazon','b',['social']],
      ['paypal','b',['social','biz']], ['stripe','b',['social','biz']],
      ['shopify','b',['social','shop']], ['wordpress','b',['social']],
      ['wordpress-simple','b',['social']], ['react','b',['social','sci']],
      ['vuejs','b',['social','sci']], ['angular','b',['social','sci']],
      ['node-js','b',['social','sci']], ['python','b',['social','sci']],
      ['php','b',['social','sci']], ['js','b',['social','sci']],
      ['html5','b',['social','sci']], ['css3','b',['social','sci']],
      ['css3-alt','b',['social','sci']], ['bootstrap','b',['social','sci']],
      ['figma','b',['social']], ['dropbox','b',['social']],
      ['steam','b',['social']], ['playstation','b',['social']], ['xbox','b',['social']],
      ['docker','b',['social','sci']], ['git','b',['social','sci']],
      ['git-alt','b',['social','sci']], ['npm','b',['social','sci']],
      ['yarn','b',['social','sci']], ['sass','b',['social','sci']],
      ['linux','b',['social','sci']], ['ubuntu','b',['social','sci']],
    ];

    // ─── Category labels ──────────────────────────────────────────────────────
    const CAT_LABELS: Record<string, string> = {
      nav: 'Interface', arrow: 'Arrows', alert: 'Alerts', edit: 'Editing',
      file: 'Files', comm: 'Communication', user: 'People', health: 'Health',
      biz: 'Business', shop: 'Shopping', travel: 'Travel', nature: 'Nature',
      food: 'Food & Drink', animal: 'Animals', sci: 'Science & Tech',
      sec: 'Security', media: 'Media', sport: 'Sports', map: 'Maps', social: 'Brands',
    };

    // ─── State ────────────────────────────────────────────────────────────────
    let selected: { name: string; style: string } | null = null;
    let currentUnicode = '????';

    // ─── DOM ──────────────────────────────────────────────────────────────────
    const versionSel  = document.getElementById('fa-version') as HTMLSelectElement;
    const styleSel    = document.getElementById('fa-style-filter') as HTMLSelectElement;
    const categorySel = document.getElementById('fa-category') as HTMLSelectElement;
    const searchEl    = document.getElementById('fa-search') as HTMLInputElement;
    const countEl     = document.getElementById('fa-count') as HTMLElement;
    const gridEl      = document.getElementById('fa-grid') as HTMLElement;
    const noResultsEl = document.getElementById('fa-no-results') as HTMLElement;
    const emptyState  = document.getElementById('fa-empty-state') as HTMLElement;
    const detailEl    = document.getElementById('fa-detail') as HTMLElement;
    const previewEl   = document.getElementById('fa-preview') as HTMLElement;
    const nameDisp    = document.getElementById('fa-name-display') as HTMLElement;
    const classDisp   = document.getElementById('fa-class-display') as HTMLElement;
    const unicodeDisp = document.getElementById('fa-unicode-display') as HTMLElement;
    const langSel     = document.getElementById('fa-lang') as HTMLSelectElement;
    const codeOut     = document.getElementById('fa-code-out') as HTMLElement;
    const copyBtn     = document.getElementById('fa-copy-code') as HTMLButtonElement;

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function styleClass(s: string): string {
      return s === 'b' ? 'fa-brands' : s === 'r' ? 'fa-regular' : 'fa-solid';
    }
    function fa5Prefix(s: string): string {
      return s === 'b' ? 'fab' : s === 'r' ? 'far' : 'fas';
    }
    function toCamel(name: string): string {
      return 'fa' + name.split('-').map((w: string) => w[0].toUpperCase() + w.slice(1)).join('');
    }
    function toPascal(name: string): string {
      return name.split('-').map((w: string) => w[0].toUpperCase() + w.slice(1)).join('');
    }
    function toLabel(name: string): string {
      return name.split('-').map((w: string) => w[0].toUpperCase() + w.slice(1)).join(' ');
    }

    /** Read the rendered unicode from FA's ::before pseudo-element */
    function readUnicode(name: string, style: string): string {
      const el = document.createElement('i');
      el.className = `${styleClass(style)} fa-${name}`;
      el.style.cssText = 'position:fixed;top:-9999px;left:-9999px;visibility:hidden;font-size:16px';
      document.body.appendChild(el);
      const content = window.getComputedStyle(el, '::before').content;
      document.body.removeChild(el);
      const m = content.match(/\\([0-9a-fA-F]+)/i);
      return m ? m[1].toLowerCase() : '????';
    }

    // ─── Code builder ────────────────────────────────────────────────────────
    function buildCode(name: string, style: string, version: string, lang: string, unicode: string): string {
      const sc  = styleClass(style);
      const fa5 = fa5Prefix(style);
      const htmlCls = version === '6' ? `${sc} fa-${name}`
                    : version === '5' ? `${fa5} fa-${name}`
                    : `fa fa-${name}`;
      const camel = toCamel(name);
      const pascal = toPascal(name);
      const pkg   = style === 'b' ? 'free-brands-svg-icons'
                  : style === 'r' ? 'free-regular-svg-icons'
                  : 'free-solid-svg-icons';
      const fw    = (style === 'b' || style === 'r') ? '400' : '900';
      const fontFam = version === '4' ? '"FontAwesome"'
                    : `"Font Awesome ${version} ${style === 'b' ? 'Brands' : 'Free'}"`;
      const cdn   = version === '4'
        ? 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css'
        : version === '5'
        ? 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css'
        : 'https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css';
      const pyPfx = `fa${version}${style}`;
      const pyName = name.replace(/-/g, '_');

      switch (lang) {
        case 'html':
          return `<!-- Add to <head> -->\n<link rel="stylesheet" href="${cdn}">\n\n<!-- Icon -->\n<i class="${htmlCls}"></i>`;
        case 'css':
          return `.my-icon::before {\n  font-family: ${fontFam};\n  font-weight: ${fw};\n  content: "\\${unicode}"; /* fa-${name} */\n}`;
        case 'react':
          return `// npm i @fortawesome/react-fontawesome @fortawesome/${pkg}\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { ${camel} } from '@fortawesome/${pkg}';\n\nexport default function MyComponent() {\n  return <FontAwesomeIcon icon={${camel}} />;\n}`;
        case 'vue':
          return `<!-- npm i @fortawesome/vue-fontawesome @fortawesome/${pkg} -->\n<template>\n  <font-awesome-icon :icon="['${fa5}', '${name}']" />\n</template>\n\n<script setup>\nimport { FontAwesomeIcon } from '@fortawesome/vue-fontawesome';\nimport { library } from '@fortawesome/fontawesome-svg-core';\nimport { ${camel} } from '@fortawesome/${pkg}';\nlibrary.add(${camel});\n<\/script>`;
        case 'angular':
          return `// npm i @fortawesome/angular-fontawesome @fortawesome/${pkg}\n\n// app.module.ts\nimport { FaIconLibrary } from '@fortawesome/angular-fontawesome';\nimport { ${camel} } from '@fortawesome/${pkg}';\nconstructor(lib: FaIconLibrary) {\n  lib.addIcons(${camel});\n}\n\n// template.html\n<fa-icon [icon]="['${fa5}', '${name}']"></fa-icon>`;
        case 'svelte':
          return `<!-- npm i @fortawesome/svelte-fontawesome @fortawesome/${pkg} -->\n<script>\n  import { FontAwesomeIcon } from '@fortawesome/svelte-fontawesome';\n  import { ${camel} } from '@fortawesome/${pkg}';\n<\/script>\n\n<FontAwesomeIcon icon={${camel}} />`;
        case 'csharp-blazor':
          return `@* Add in wwwroot/index.html <head>: *@\n<link rel="stylesheet" href="${cdn}" />\n\n@* .razor component *@\n<i class="${htmlCls}"></i>`;
        case 'csharp-maui':
          return `// NuGet: FontAwesome.Sharp\n// Register in MauiProgram.cs:\n// .ConfigureFonts(fonts => {\n//     fonts.AddFont("fa-solid-900.ttf", "FA6Solid");\n//     fonts.AddFont("fa-brands-400.ttf", "FA6Brands");\n// })\n\n<!-- XAML -->\n<Label Text="&#x${unicode};"\n       FontFamily="${style === 'b' ? 'FA6Brands' : 'FA6Solid'}" />\n\n<!-- FontImageSource -->\n<FontImageSource Glyph="&#x${unicode};"\n                 FontFamily="${style === 'b' ? 'FA6Brands' : 'FA6Solid'}" />`;
        case 'python':
          return `# pip install qtawesome\nimport qtawesome as qta\n\n# ${toLabel(name)} icon\nicon = qta.icon('${pyPfx}.${pyName}')\n\n# Apply to a widget\nbutton.setIcon(icon)\n# Or get a pixmap\npixmap = qta.icon('${pyPfx}.${pyName}').pixmap(32, 32)`;
        case 'php':
          return `<?php\n// Add to HTML <head>:\n// <link rel="stylesheet" href="${cdn}">\n\necho '<i class="${htmlCls}"></i>';\n?>`;
        case 'wordpress':
          return `<?php\n// functions.php — enqueue Font Awesome\nfunction theme_enqueue_fa() {\n    wp_enqueue_style(\n        'font-awesome',\n        '${cdn}'\n    );\n}\nadd_action('wp_enqueue_scripts', 'theme_enqueue_fa');\n\n// Template output\necho '<i class="${htmlCls}"></i>';\n\n// wp_kses safe output\necho wp_kses(\n    '<i class="${htmlCls}"></i>',\n    ['i' => ['class' => []]]\n);\n?>`;
        default:
          return `<i class="${htmlCls}"></i>`;
      }
    }

    // ─── Populate category dropdown ───────────────────────────────────────────
    function populateCategories() {
      const used = new Set<string>();
      for (const [,,cats] of ICON_DATA) cats.forEach((c: string) => used.add(c));
      while (categorySel.options.length > 1) categorySel.remove(1);
      for (const [key, label] of Object.entries(CAT_LABELS)) {
        if (!used.has(key)) continue;
        const opt = document.createElement('option');
        opt.value = key; opt.textContent = label;
        categorySel.appendChild(opt);
      }
    }

    // ─── Render grid ──────────────────────────────────────────────────────────
    function renderGrid() {
      const sf = styleSel.value;
      const cf = categorySel.value;
      const q  = searchEl.value.toLowerCase().trim();

      const filtered = ICON_DATA.filter(([name, style, cats]) => {
        if (sf !== 'all' && style !== sf) return false;
        if (cf !== 'all' && !cats.includes(cf)) return false;
        if (q && !name.includes(q)) return false;
        return true;
      });

      countEl.textContent = `${filtered.length} icon${filtered.length !== 1 ? 's' : ''}`;
      gridEl.innerHTML = '';
      noResultsEl.style.display = filtered.length === 0 ? '' : 'none';
      if (filtered.length === 0) return;

      const frag = document.createDocumentFragment();
      for (const [name, style] of filtered) {
        const sc = styleClass(style);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'fa-tile' + (selected?.name === name && selected?.style === style ? ' selected' : '');
        btn.dataset.name = name;
        btn.dataset.style = style;
        btn.title = name;
        btn.innerHTML = `<i class="${sc} fa-${name}" aria-hidden="true"></i><span class="fa-tile-name">${name}</span>`;
        btn.addEventListener('click', () => selectIcon(name, style, btn));
        frag.appendChild(btn);
      }
      gridEl.appendChild(frag);
    }

    // ─── Select an icon ───────────────────────────────────────────────────────
    function selectIcon(name: string, style: string, btn: HTMLButtonElement) {
      document.querySelectorAll('.fa-tile.selected').forEach(el => el.classList.remove('selected'));
      btn.classList.add('selected');
      selected = { name, style };
      currentUnicode = readUnicode(name, style);

      const sc = styleClass(style);
      emptyState.style.display  = 'none';
      detailEl.style.display    = 'flex';

      previewEl.innerHTML = `<i class="${sc} fa-${name}" aria-hidden="true"></i>`;
      nameDisp.textContent  = toLabel(name);
      classDisp.textContent = `${sc} fa-${name}`;
      unicodeDisp.textContent = currentUnicode !== '????' ? `U+${currentUnicode.toUpperCase()} · \\${currentUnicode}` : '';

      codeOut.textContent = buildCode(name, style, versionSel.value, langSel.value, currentUnicode);
    }

    function refreshCode() {
      if (!selected) return;
      codeOut.textContent = buildCode(selected.name, selected.style, versionSel.value, langSel.value, currentUnicode);
    }

    // ─── Events ──────────────────────────────────────────────────────────────
    styleSel.addEventListener('change', renderGrid);
    categorySel.addEventListener('change', renderGrid);
    searchEl.addEventListener('input', renderGrid);
    versionSel.addEventListener('change', refreshCode);
    langSel.addEventListener('change', refreshCode);
    copyBtn.addEventListener('click', async () => {
      const text = codeOut.textContent ?? '';
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const orig = copyBtn.textContent ?? '';
        copyBtn.textContent = '✓ Copied!';
        setTimeout(() => { copyBtn.textContent = orig; }, 1500);
      } catch { /* ignore */ }
    });

    // ─── Init ─────────────────────────────────────────────────────────────────
    populateCategories();
    renderGrid();
  </script>
</BaseLayout>
