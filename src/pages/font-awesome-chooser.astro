---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Font Awesome Chooser"
  description="Browse Font Awesome 6 icons by category and style. Click any icon to get usage code for HTML, CSS, React, Vue, Angular, C#, Python, PHP, WordPress, and more.">
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css"
    crossorigin="anonymous"
  />

  <main class="shell fa-main">
    <header class="fa-page-header">
      <h1>Font Awesome Chooser</h1>
      <p>Browse icons by category · click any icon to get code in your language</p>
    </header>

    <!-- Controls bar -->
    <div class="fa-controls">
      <div class="fa-ctl">
        <label for="fa-version">FA Version</label>
        <select id="fa-version">
          <option value="6" selected>Font Awesome 6</option>
          <option value="5">Font Awesome 5</option>
          <option value="4">Font Awesome 4</option>
        </select>
      </div>
      <div class="fa-ctl">
        <label for="fa-style-filter">Style</label>
        <select id="fa-style-filter">
          <option value="all" selected>All styles</option>
          <option value="s">Solid</option>
          <option value="r">Regular</option>
          <option value="b">Brands</option>
        </select>
      </div>
      <div class="fa-ctl">
        <label for="fa-category">Category</label>
        <select id="fa-category">
          <option value="all">All categories</option>
        </select>
      </div>
      <div class="fa-ctl fa-ctl-search">
        <label for="fa-search">Search</label>
        <div class="fa-search-wrap">
          <i class="fa-solid fa-magnifying-glass fa-search-icon" aria-hidden="true"></i>
          <input type="search" id="fa-search" placeholder="filter icons…" autocomplete="off" spellcheck="false" />
        </div>
      </div>
      <span class="fa-count" id="fa-count"></span>
    </div>

    <!-- Workspace: scrollable grid + detail sidebar -->
    <div class="fa-workspace">
      <div class="fa-grid-wrap">
        <div class="fa-grid" id="fa-grid"></div>
        <p class="fa-no-results" id="fa-no-results" style="display:none">No icons match your filters.</p>
      </div>

      <aside class="fa-sidebar">
        <div class="fa-empty-state" id="fa-empty-state">
          <p>Click any icon to see usage code</p>
        </div>
        <div class="fa-detail" id="fa-detail" style="display:none">
          <div class="fa-preview" id="fa-preview"></div>
          <div class="fa-icon-meta">
            <strong id="fa-name-display"></strong>
            <code id="fa-class-display" class="fa-code-inline"></code>
            <span id="fa-unicode-display" class="fa-muted-text"></span>
          </div>
          <div class="fa-ctl fa-lang-ctl">
            <label for="fa-lang">Language / Framework</label>
            <select id="fa-lang">
              <option value="html">HTML</option>
              <option value="css">CSS (content:)</option>
              <option value="react">React / JSX</option>
              <option value="vue">Vue 3</option>
              <option value="angular">Angular</option>
              <option value="svelte">Svelte</option>
              <option value="csharp-blazor">C# — Blazor</option>
              <option value="csharp-maui">C# — MAUI / WPF</option>
              <option value="python">Python (qtawesome)</option>
              <option value="php">PHP</option>
              <option value="wordpress">WordPress PHP</option>
            </select>
          </div>
          <div class="fa-code-wrap">
            <pre id="fa-code-out" class="fa-code"></pre>
          </div>
          <button class="button primary fa-copy-btn" id="fa-copy-code">⎘ Copy code</button>
        </div>
      </aside>
    </div>
  </main>

  <style>
    /* ── Page ──────────────────────────────────────────── */
    .fa-main { padding: 1rem 0 1rem; }
    .fa-page-header { margin-bottom: 0.6rem; }
    .fa-page-header h1 { margin: 0; font-size: clamp(1.4rem, 2.5vw, 1.9rem); }
    .fa-page-header p { margin: 0.15rem 0 0; color: var(--muted); font-size: 0.85rem; }

    /* ── Controls ──────────────────────────────────────── */
    .fa-controls {
      display: flex;
      align-items: flex-end;
      gap: 0.65rem;
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .fa-ctl { display: flex; flex-direction: column; gap: 0.2rem; }
    .fa-ctl label { font-size: 0.75rem; color: var(--muted); font-weight: 500; }
    .fa-ctl select {
      min-height: 2.1rem;
      font-size: 0.88rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--panel-muted);
      color: var(--text);
      padding: 0.3rem 0.6rem;
      font: inherit;
    }
    .fa-ctl-search { flex: 1; min-width: 160px; }
    .fa-search-wrap { position: relative; }
    .fa-search-icon {
      position: absolute;
      left: 0.6rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 0.82rem;
      pointer-events: none;
    }
    #fa-search {
      width: 100%;
      min-height: 2.1rem;
      padding: 0.3rem 0.6rem 0.3rem 2rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--panel-muted);
      color: var(--text);
      font-size: 0.88rem;
      font: inherit;
    }
    #fa-search:focus {
      outline: 3px solid color-mix(in srgb, var(--accent) 40%, transparent);
      outline-offset: 1px;
    }
    .fa-count {
      color: var(--muted);
      font-size: 0.8rem;
      align-self: flex-end;
      padding-bottom: 0.4rem;
      white-space: nowrap;
      min-width: 6rem;
    }

    /* ── Workspace ─────────────────────────────────────── */
    .fa-workspace {
      display: grid;
      grid-template-columns: 1fr 290px;
      gap: 0.75rem;
      height: calc(100vh - 230px);
      min-height: 420px;
      margin-top: 0.65rem;
    }

    /* ── Icon grid ─────────────────────────────────────── */
    .fa-grid-wrap {
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--panel);
    }
    .fa-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
      gap: 0.25rem;
      padding: 0.6rem;
    }
    .fa-no-results {
      padding: 2rem;
      text-align: center;
      color: var(--muted);
      font-size: 0.9rem;
      margin: 0;
    }
    .fa-tile {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 0.28rem;
      padding: 0.5rem 0.2rem 0.4rem;
      border-radius: 6px;
      cursor: pointer;
      border: 2px solid transparent;
      background: transparent;
      color: var(--text);
      text-align: center;
      transition: border-color 0.1s, background 0.1s;
      min-width: 0;
    }
    .fa-tile:hover { background: var(--panel-muted); border-color: var(--border); }
    .fa-tile.selected {
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      border-color: var(--accent);
    }
    .fa-tile i { font-size: 1.35rem; line-height: 1; }
    .fa-tile-name {
      font-size: 0.59rem;
      color: var(--muted);
      word-break: break-all;
      line-height: 1.2;
      max-width: 100%;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    /* ── Sidebar ───────────────────────────────────────── */
    .fa-sidebar {
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--panel);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }
    .fa-empty-state {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      padding: 1.5rem;
      text-align: center;
    }
    .fa-empty-state p { margin: 0; font-size: 0.88rem; }
    .fa-detail {
      padding: 0.85rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .fa-preview {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 82px;
      background: var(--panel-muted);
      border-radius: 8px;
      border: 1px solid var(--border);
      flex-shrink: 0;
    }
    .fa-preview i { font-size: 2.8rem; color: var(--accent); }
    .fa-icon-meta { display: flex; flex-direction: column; gap: 0.15rem; }
    .fa-icon-meta strong { font-size: 0.95rem; }
    .fa-code-inline {
      font-family: ui-monospace, 'Cascadia Code', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      word-break: break-all;
    }
    .fa-muted-text { font-size: 0.72rem; color: var(--muted); font-family: ui-monospace, monospace; }
    .fa-lang-ctl { width: 100%; }
    .fa-lang-ctl select { width: 100%; }
    .fa-code-wrap {
      background: var(--panel-muted);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: auto;
      min-height: 80px;
      max-height: 280px;
    }
    .fa-code {
      margin: 0;
      padding: 0.6rem 0.75rem;
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.74rem;
      line-height: 1.55;
      color: var(--accent);
      white-space: pre;
    }
    .fa-copy-btn { width: 100%; font-size: 0.88rem; min-height: 2.1rem; }

    /* ── Narrow fallback ───────────────────────────────── */
    @media (max-width: 760px) {
      .fa-workspace { grid-template-columns: 1fr; height: auto; }
      .fa-grid-wrap { height: 50vh; }
      .fa-sidebar { min-height: 320px; }
    }
  </style>

