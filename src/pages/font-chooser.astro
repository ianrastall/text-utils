        'Barlow Condensed': ['100', '200', '300', '400', '500', '600', '700', '800', '900'],
        'Yanone Kaffeesatz': ['200', '300', '400', '500', '600', '700'],
        'Fjalla One': ['400'],
        'Staatliches': ['400'],
