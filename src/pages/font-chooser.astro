---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Font Chooser"
  description="Preview and select fonts with Google Fonts integration, accessibility checking, and production-ready CSS generation.">

  <main class="shell page-main fc-page">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Font Chooser</h1>
        <p>Preview and select fonts with Google Fonts integration, accessibility checking, and production-ready CSS generation.</p>
      </div>
    </div>

    <div class="fc-layout">
      <!-- Sidebar -->
      <aside class="fc-sidebar panel">
        <h3 style="margin-top: 0; font-size: 1.1rem; margin-bottom: 1rem;">Font Source</h3>
        
        <div class="fc-source-radios" style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="radio" name="fontSource" value="google" checked> 
            <span>Google Fonts <span style="font-size: 0.7rem; background: var(--accent); color: white; padding: 2px 6px; border-radius: 10px;">100+</span></span>
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="radio" name="fontSource" value="system">
            <span>System Fonts</span>
          </label>
        </div>

        <div class="field" style="margin-bottom: 1rem;">
          <input type="text" id="fontSearch" placeholder="Search fonts..." style="width: 100%; padding: 0.4rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);" />
        </div>

        <div class="field" id="categoryFilterContainer" style="margin-bottom: 1rem;">
          <select id="fontCategory" style="width: 100%; padding: 0.4rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);">
            <option value="all">All Categories</option>
            <option value="serif">Serif</option>
            <option value="sans-serif">Sans Serif</option>
            <option value="display">Display</option>
            <option value="handwriting">Handwriting</option>
            <option value="monospace">Monospace</option>
          </select>
        </div>

        <div id="fontList" class="fc-font-list">
          <!-- Populated by JS -->
        </div>
      </aside>

      <!-- Main Column -->
      <div class="fc-main">
        <!-- Settings Panel -->
        <div class="fc-settings panel" style="margin-bottom: 1.5rem;">
          <h3 style="margin-top: 0; font-size: 1.1rem; margin-bottom: 1rem;">Preview Settings</h3>
          
          <div class="fc-controls-grid">
            <div class="field">
              <label>Font Size (<span id="fontSizeDisplay">16</span>px)</label>
              <input type="range" id="fontSize" min="8" max="72" value="16" />
            </div>
            
            <div class="field">
              <label>Font Weight</label>
              <select id="fontWeight" style="padding: 0.3rem;">
                <option value="400" selected>400 - Regular</option>
              </select>
            </div>
            
            <div class="field">
              <label>Line Height (<span id="lineHeightDisplay">1.5</span>)</label>
              <input type="range" id="lineHeight" min="1" max="3" step="0.1" value="1.5" />
            </div>
            
            <div class="field">
              <label>Letter Spacing (<span id="letterSpacingDisplay">0</span>px)</label>
              <input type="range" id="letterSpacing" min="-5" max="10" step="0.5" value="0" />
            </div>
            
            <div class="field">
              <label>Text Color</label>
              <div style="display: flex; gap: 0.5rem;">
                <input type="color" id="textColor" value="#ffffff" style="width: 40px; height: 32px; padding: 0; cursor: pointer;" />
                <input type="text" id="textColorHex" value="#ffffff" style="flex: 1; padding: 0.3rem;" />
              </div>
            </div>
            
            <div class="field">
              <label>Background Color</label>
              <div style="display: flex; gap: 0.5rem;">
                <input type="color" id="bgColor" value="#1a1a1a" style="width: 40px; height: 32px; padding: 0; cursor: pointer;" />
                <input type="text" id="bgColorHex" value="#1a1a1a" style="flex: 1; padding: 0.3rem;" />
              </div>
            </div>

            <div class="field">
              <label>Contrast Ratio</label>
              <div id="contrastBadge" style="margin-top: 0.3rem;">
                <!-- Filled by JS -->
              </div>
            </div>

            <div class="field" style="grid-column: 1 / -1;">
              <label>Custom Text</label>
              <input type="text" id="customText" value="The quick brown fox jumps over the lazy dog." style="width: 100%; padding: 0.4rem;" />
            </div>
          </div>
        </div>

        <!-- Preview Panel -->
        <div class="fc-preview panel" style="margin-bottom: 1.5rem; overflow: hidden;">
          <h3 style="margin-top: 0; font-size: 1.1rem; margin-bottom: 1rem; display: flex; justify-content: space-between;">
            Preview
            <button class="button" id="resetBtn" style="font-size: 0.8rem; padding: 0.2rem 0.6rem;">Reset</button>
          </h3>
          <div id="previewArea" style="min-height: 250px; padding: 2rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg); color: var(--text); overflow-wrap: break-word;">
            <div id="previewContent">
              <p class="preview-text">The quick brown fox jumps over the lazy dog.</p>
              <p class="preview-text">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
              <p class="preview-text">abcdefghijklmnopqrstuvwxyz</p>
              <p class="preview-text">0123456789</p>
            </div>
          </div>
        </div>

        <!-- Code Panel -->
        <div class="fc-code panel">
          <h3 style="margin-top: 0; font-size: 1.1rem; margin-bottom: 1rem;">Production-Ready CSS</h3>
          
          <div class="fc-tabs">
            <button class="fc-tab active" data-tab="css">CSS</button>
            <button class="fc-tab" data-tab="import">@import</button>
            <button class="fc-tab" data-tab="scss">SCSS</button>
          </div>
          
          <div class="fc-tab-content active" id="tab-css">
            <div class="fc-code-wrap">
              <pre><code id="code-css">/* Select a font */</code></pre>
              <button class="button copy-btn" data-target="code-css">⎘ Copy</button>
            </div>
          </div>
          <div class="fc-tab-content" id="tab-import" style="display: none;">
            <div class="fc-code-wrap">
              <pre><code id="code-import">/* Select a font */</code></pre>
              <button class="button copy-btn" data-target="code-import">⎘ Copy</button>
            </div>
          </div>
          <div class="fc-tab-content" id="tab-scss" style="display: none;">
            <div class="fc-code-wrap">
              <pre><code id="code-scss">/* Select a font */</code></pre>
              <button class="button copy-btn" data-target="code-scss">⎘ Copy</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div id="toastContainer" class="toast-container"></div>

  <style is:global>
    .page-main { padding: 1.5rem 0 3rem; }
    
    .fc-layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    @media (max-width: 800px) {
      .fc-layout { grid-template-columns: 1fr; }
    }

    .fc-font-list {
      height: 600px;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg);
      padding: 0.5rem;
    }

    .fc-category-header {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin: 1rem 0 0.5rem 0.5rem;
    }
    .fc-category-header:first-child { margin-top: 0.5rem; }

    .fc-font-item {
      padding: 0.5rem;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.2s;
    }
    .fc-font-item:hover { background: var(--panel-muted); }
    .fc-font-item.active {
      background: var(--panel-muted);
      border-left: 3px solid var(--accent);
    }
    .fc-font-item-name { font-size: 1rem; }
    .fc-font-item-meta { font-size: 0.75rem; color: var(--muted); }

    .fc-controls-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }
    .fc-controls-grid label { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.25rem; display: block; }
    .fc-controls-grid input[type="range"] { width: 100%; }

    .contrast-badge {
      display: inline-block;
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: bold;
    }
    .contrast-pass { background: #198754; color: white; }
    .contrast-aa { background: #ffc107; color: black; }
    .contrast-fail { background: #dc3545; color: white; }

    .fc-tabs {
      display: flex;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
    }
    .fc-tab {
      background: none; border: none; color: var(--muted);
      padding: 0.5rem 1rem; cursor: pointer; font-size: 0.9rem;
      border-bottom: 2px solid transparent;
    }
    .fc-tab.active { color: var(--text); border-bottom-color: var(--accent); }
    
    .fc-code-wrap { position: relative; background: #0d1117; padding: 1rem; border-radius: 6px; border: 1px solid var(--border); }
    .fc-code-wrap pre { margin: 0; color: #e6edf3; font-family: monospace; font-size: 0.9rem; white-space: pre-wrap; }
    .copy-btn { position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.75rem; padding: 0.2rem 0.5rem; }

    /* Toasts */
    .toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; z-index: 9999; }
    .toast { background: var(--panel); color: var(--text); border: 1px solid var(--border); border-radius: 6px; padding: 0.75rem 1rem; box-shadow: var(--shadow); display: flex; align-items: center; gap: 0.75rem; animation: slideIn 0.3s ease-out forwards; border-left: 4px solid var(--accent); }
    .toast.hiding { animation: fadeOut 0.3s ease-in forwards; }
    @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @keyframes fadeOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
  </style>

  <script>
    const GOOGLE_FONTS = {
      'sans-serif': {
        'Roboto': ['100', '300', '400', '500', '700', '900'],
        'Open Sans': ['300', '400', '500', '600', '700', '800'],
        'Lato': ['100', '300', '400', '700', '900'],
