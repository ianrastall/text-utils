      },
      'monospace': {
        'Roboto Mono': ['100', '200', '300', '400', '500', '600', '700'],
        'Source Code Pro': ['200', '300', '400', '500', '600', '700', '800', '900'],
        'Fira Code': ['300', '400', '500', '600', '700'],
        'JetBrains Mono': ['100', '200', '300', '400', '500', '600', '700', '800'],
        'IBM Plex Mono': ['100', '200', '300', '400', '500', '600', '700'],
        'Inconsolata': ['200', '300', '400', '500', '600', '700', '800', '900'],
        'Space Mono': ['400', '700'],
        'Ubuntu Mono': ['400', '700'],
        'Overpass Mono': ['300', '400', '600', '700'],
        'Red Hat Mono': ['300', '400', '500', '600', '700'],
        'Cousine': ['400', '700'],
        'Anonymous Pro': ['400', '700'],
        'VT323': ['400'],
        'Share Tech Mono': ['400'],
      },
      'handwriting': {
        'Dancing Script': ['400', '500', '600', '700'],
        'Pacifico': ['400'],
        'Caveat': ['400', '500', '600', '700'],
        'Satisfy': ['400'],
        'Great Vibes': ['400'],
        'Cookie': ['400'],
        'Permanent Marker': ['400'],
        'Kalam': ['300', '400', '700'],
        'Patrick Hand': ['400'],
        'Shadows Into Light': ['400'],
        'Indie Flower': ['400'],
        'Amatic SC': ['400', '700'],
        'Handlee': ['400'],
        'Sacramento': ['400'],
        'Courgette': ['400'],
      }
    };

    const SYSTEM_FONTS = {
      'all': {
        'Arial': 'Arial, Helvetica, sans-serif',
        'Georgia': 'Georgia, serif',
        'Courier New': '"Courier New", Courier, monospace',
        'Times New Roman': '"Times New Roman", Times, serif',
        'Verdana': 'Verdana, Geneva, sans-serif',
        'Tahoma': 'Tahoma, Geneva, sans-serif',
        'Trebuchet MS': '"Trebuchet MS", Helvetica, sans-serif',
        'Impact': 'Impact, Charcoal, sans-serif',
        'Comic Sans MS': '"Comic Sans MS", cursive',
      },
      'windows': {
        'Segoe UI': '"Segoe UI", Tahoma, Geneva, sans-serif',
        'Calibri': 'Calibri, Candara, sans-serif',
        'Cambria': 'Cambria, Georgia, serif',
        'Consolas': 'Consolas, Monaco, monospace',
      },
      'mac': {
        'San Francisco': '-apple-system, BlinkMacSystemFont, sans-serif',
        'Helvetica Neue': '"Helvetica Neue", Helvetica, Arial, sans-serif',
        'Avenir': 'Avenir, "Avenir Next", sans-serif',
        'Monaco': 'Monaco, Consolas, monospace',
      },
      'linux': {
        'Ubuntu': 'Ubuntu, "Noto Sans", sans-serif',
        'DejaVu Sans': '"DejaVu Sans", Verdana, sans-serif',
        'Liberation Sans': '"Liberation Sans", Arial, sans-serif',
      }
    };

    const dom = {
      fontList: document.getElementById('fontList') as HTMLDivElement,
      fontSearch: document.getElementById('fontSearch') as HTMLInputElement,
      fontCategory: document.getElementById('fontCategory') as HTMLSelectElement,
      catFilterContainer: document.getElementById('categoryFilterContainer') as HTMLDivElement,
      radios: document.getElementsByName('fontSource') as NodeListOf<HTMLInputElement>,
      
      fontSize: document.getElementById('fontSize') as HTMLInputElement,
      fontSizeDisplay: document.getElementById('fontSizeDisplay') as HTMLSpanElement,
      fontWeight: document.getElementById('fontWeight') as HTMLSelectElement,
      lineHeight: document.getElementById('lineHeight') as HTMLInputElement,
      lineHeightDisplay: document.getElementById('lineHeightDisplay') as HTMLSpanElement,
      letterSpacing: document.getElementById('letterSpacing') as HTMLInputElement,
      letterSpacingDisplay: document.getElementById('letterSpacingDisplay') as HTMLSpanElement,
      
      textColor: document.getElementById('textColor') as HTMLInputElement,
      textColorHex: document.getElementById('textColorHex') as HTMLInputElement,
      bgColor: document.getElementById('bgColor') as HTMLInputElement,
      bgColorHex: document.getElementById('bgColorHex') as HTMLInputElement,
      contrastBadge: document.getElementById('contrastBadge') as HTMLDivElement,
      customText: document.getElementById('customText') as HTMLInputElement,
      
      previewArea: document.getElementById('previewArea') as HTMLDivElement,
      previewContent: document.getElementById('previewContent') as HTMLDivElement,
      resetBtn: document.getElementById('resetBtn') as HTMLButtonElement,
      
      tabs: document.querySelectorAll('.fc-tab'),
      tabContents: document.querySelectorAll('.fc-tab-content'),
      codeCss: document.getElementById('code-css') as HTMLElement,
      codeImport: document.getElementById('code-import') as HTMLElement,
      codeScss: document.getElementById('code-scss') as HTMLElement,
      copyBtns: document.querySelectorAll('.copy-btn'),
      toastContainer: document.getElementById('toastContainer') as HTMLDivElement
    };

    let currentSource = 'google';
    let currentFont = { name: '', familyDef: '', source: 'google' };
    let activeOS = 'all';

    // --- OS Detection ---
    const ua = navigator.userAgent.toLowerCase();
    if (ua.includes('win')) activeOS = 'windows';
    else if (ua.includes('mac')) activeOS = 'mac';
    else if (ua.includes('linux')) activeOS = 'linux';

    // --- Font List Rendering ---
    function renderFontList() {
      dom.fontList.innerHTML = '';
      const search = dom.fontSearch.value.toLowerCase();
      const categoryFilter = dom.fontCategory.value;

      if (currentSource === 'google') {
        dom.catFilterContainer.style.display = 'block';
        for (const [cat, fonts] of Object.entries(GOOGLE_FONTS)) {
          if (categoryFilter !== 'all' && categoryFilter !== cat) continue;
          
          const filteredFonts = Object.keys(fonts).filter(f => f.toLowerCase().includes(search));
          if (filteredFonts.length === 0) continue;

          const catHeader = document.createElement('div');
          catHeader.className = 'fc-category-header';
          catHeader.textContent = `${cat} (${filteredFonts.length})`;
          dom.fontList.appendChild(catHeader);

          filteredFonts.forEach(fontName => {
            const weights = (fonts as Record<string, string[]>)[fontName];
            const item = document.createElement('div');
            item.className = 'fc-font-item';
            item.innerHTML = `
              <span class="fc-font-item-name" style="font-family: '${fontName}', sans-serif">${fontName}</span>
              <span class="fc-font-item-meta">${weights.length} styles</span>
            `;
            item.onclick = () => selectFont(fontName, `'${fontName}', ${cat}`, 'google', item, weights);
            dom.fontList.appendChild(item);
          });
        }
      } else {
        dom.catFilterContainer.style.display = 'none';
        
        // Render Web Safe
        const safeFonts = Object.keys(SYSTEM_FONTS.all).filter(f => f.toLowerCase().includes(search));
        if (safeFonts.length > 0) {
          const catHeader = document.createElement('div');
          catHeader.className = 'fc-category-header';
          catHeader.textContent = `Web Safe Fonts`;
          dom.fontList.appendChild(catHeader);
          safeFonts.forEach(fontName => {
            const familyDef = SYSTEM_FONTS.all[fontName as keyof typeof SYSTEM_FONTS.all];
            const item = document.createElement('div');
            item.className = 'fc-font-item';
            item.innerHTML = `<span class="fc-font-item-name" style="font-family: ${familyDef}">${fontName}</span><span class="fc-font-item-meta" style="color:var(--success)">Universal</span>`;
            item.onclick = () => selectFont(fontName, familyDef, 'system', item);
            dom.fontList.appendChild(item);
          });
        }

        // Render OS Specific
        if (SYSTEM_FONTS[activeOS as keyof typeof SYSTEM_FONTS]) {
          const osFonts = Object.keys(SYSTEM_FONTS[activeOS as keyof typeof SYSTEM_FONTS]).filter(f => f.toLowerCase().includes(search));
          if (osFonts.length > 0) {
            const catHeader = document.createElement('div');
            catHeader.className = 'fc-category-header';
            catHeader.textContent = `Your System (${activeOS})`;
            dom.fontList.appendChild(catHeader);
            osFonts.forEach(fontName => {
              const familyDef = (SYSTEM_FONTS[activeOS as keyof typeof SYSTEM_FONTS] as Record<string, string>)[fontName];
              const item = document.createElement('div');
              item.className = 'fc-font-item';
              item.innerHTML = `<span class="fc-font-item-name" style="font-family: ${familyDef}">${fontName}</span><span class="fc-font-item-meta" style="color:var(--accent)">${activeOS}</span>`;
              item.onclick = () => selectFont(fontName, familyDef, 'system', item);
              dom.fontList.appendChild(item);
            });
          }
        }
      }

      if (dom.fontList.children.length === 0) {
        dom.fontList.innerHTML = '<div style="padding: 1rem; color: var(--muted); text-align: center;">No fonts found.</div>';
      } else if (!currentFont.name) {
        // Auto select first
        const first = dom.fontList.querySelector('.fc-font-item') as HTMLElement;
        if (first) first.click();
      } else {
        // re-highlight current
        const items = dom.fontList.querySelectorAll('.fc-font-item');
        items.forEach((item: any) => {
          if (item.querySelector('.fc-font-item-name').textContent === currentFont.name) {
            item.classList.add('active');
          }
        });
      }
    }

    function selectFont(name: string, familyDef: string, source: string, itemEl: HTMLElement, weights?: string[]) {
      document.querySelectorAll('.fc-font-item').forEach(i => i.classList.remove('active'));
      itemEl.classList.add('active');
      currentFont = { name, familyDef, source };

      if (source === 'google') {
        const linkId = 'google-font-link';
        let link = document.getElementById(linkId) as HTMLLinkElement;
        if (!link) {
          link = document.createElement('link');
          link.id = linkId;
          link.rel = 'stylesheet';
          document.head.appendChild(link);
        }
        const encodedFamily = encodeURIComponent(name);
        const wghts = weights ? weights.join(';') : '400';
        link.href = `https://fonts.googleapis.com/css2?family=${encodedFamily}:wght@${wghts}&display=swap`;
        
        updateWeightsDropdown(weights || ['400']);
      } else {
        updateWeightsDropdown(['300', '400', '500', '600', '700']);
      }

      applyPreviewStyles();
      generateCode();
    }

    function updateWeightsDropdown(weights: string[]) {
      const current = dom.fontWeight.value;
      dom.fontWeight.innerHTML = '';
      const map: Record<string, string> = { '100':'Thin', '200':'Extra Light', '300':'Light', '400':'Regular', '500':'Medium', '600':'Semi Bold', '700':'Bold', '800':'Extra Bold', '900':'Black' };
      
      let hasCurrent = false;
      weights.forEach(w => {
        const opt = document.createElement('option');
        opt.value = w;
        opt.textContent = `${w} - ${map[w] || 'Custom'}`;
        if (w === current) hasCurrent = true;
        dom.fontWeight.appendChild(opt);
      });
      dom.fontWeight.value = hasCurrent ? current : weights[0];
    }

    // --- Preview & Typography ---
    function applyPreviewStyles() {
      dom.previewArea.style.fontFamily = currentFont.familyDef;
      dom.previewArea.style.fontSize = `${dom.fontSize.value}px`;
      dom.previewArea.style.fontWeight = dom.fontWeight.value;
      dom.previewArea.style.lineHeight = dom.lineHeight.value;
      dom.previewArea.style.letterSpacing = `${dom.letterSpacing.value}px`;
      dom.previewArea.style.color = dom.textColor.value;
      dom.previewArea.style.backgroundColor = dom.bgColor.value;
      
      dom.fontSizeDisplay.textContent = dom.fontSize.value;
      dom.lineHeightDisplay.textContent = dom.lineHeight.value;
      dom.letterSpacingDisplay.textContent = dom.letterSpacing.value;

      document.querySelectorAll('.preview-text').forEach((el: any) => {
        el.textContent = dom.customText.value || 'The quick brown fox jumps over the lazy dog.';
      });
    }

    // --- Contrast ---
    function getLuminance(hex: string) {
      const rgb = (hex.match(/\w\w/g) || []).map(c => parseInt(c, 16) / 255);
      const [r, g, b] = rgb.map(c => c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4));
      return 0.2126 * r + 0.7152 * g + 0.0722 * b;
    }
    function updateContrast() {
      const l1 = getLuminance(dom.textColor.value);
      const l2 = getLuminance(dom.bgColor.value);
      const lighter = Math.max(l1, l2);
      const darker = Math.min(l1, l2);
      const ratio = (lighter + 0.05) / (darker + 0.05);
      const num = ratio.toFixed(2);
      
      if (ratio >= 7) {
        dom.contrastBadge.innerHTML = `<span class="contrast-badge contrast-pass">AAA (${num}:1)</span>`;
      } else if (ratio >= 4.5) {
        dom.contrastBadge.innerHTML = `<span class="contrast-badge contrast-aa">AA (${num}:1)</span>`;
      } else {
        dom.contrastBadge.innerHTML = `<span class="contrast-badge contrast-fail">FAIL (${num}:1)</span>`;
      }
    }

    // --- Code Gen ---
    function generateCode() {
      const { name, familyDef, source } = currentFont;
      const w = dom.fontWeight.value;

      dom.codeCss.textContent = `.my-text {
  font-family: ${familyDef};
  font-weight: ${w};
  font-size: ${dom.fontSize.value}px;
  line-height: ${dom.lineHeight.value};
  letter-spacing: ${dom.letterSpacing.value}px;
  color: ${dom.textColor.value};
  background-color: ${dom.bgColor.value};
}`;

      if (source === 'google') {
        const encoded = name.replace(/ /g, '+');
        dom.codeImport.textContent = `@import url('https://fonts.googleapis.com/css2?family=${encoded}:wght@${w}&display=swap');`;
      } else {
        dom.codeImport.textContent = `/* @import not needed for system fonts */`;
      }

      dom.codeScss.textContent = `$font-${name.toLowerCase().replace(/ /g, '-')}: ${familyDef};\n$text-color: ${dom.textColor.value};\n$bg-color: ${dom.bgColor.value};\n\n.my-text {\n  font-family: $font-${name.toLowerCase().replace(/ /g, '-')};\n  font-weight: ${w};\n  color: $text-color;\n  background-color: $bg-color;\n}`;
    }

    // --- Listeners ---
    dom.radios.forEach(r => r.addEventListener('change', (e: any) => {
      currentSource = e.target.value;
      currentFont.name = ''; // force reselect
      renderFontList();
    }));

    dom.fontSearch.addEventListener('input', renderFontList);
    dom.fontCategory.addEventListener('change', renderFontList);

    [dom.fontSize, dom.fontWeight, dom.lineHeight, dom.letterSpacing, dom.customText].forEach(el => {
      el.addEventListener('input', () => { applyPreviewStyles(); generateCode(); });
    });

    dom.textColor.addEventListener('input', (e: any) => { dom.textColorHex.value = e.target.value; applyPreviewStyles(); updateContrast(); generateCode(); });
    dom.textColorHex.addEventListener('input', (e: any) => { if (/^#[0-9A-F]{6}$/i.test(e.target.value)) { dom.textColor.value = e.target.value; applyPreviewStyles(); updateContrast(); generateCode(); } });
    
    dom.bgColor.addEventListener('input', (e: any) => { dom.bgColorHex.value = e.target.value; applyPreviewStyles(); updateContrast(); generateCode(); });
    dom.bgColorHex.addEventListener('input', (e: any) => { if (/^#[0-9A-F]{6}$/i.test(e.target.value)) { dom.bgColor.value = e.target.value; applyPreviewStyles(); updateContrast(); generateCode(); } });

    dom.resetBtn.addEventListener('click', () => {
      dom.fontSize.value = '16';
      dom.fontWeight.value = '400';
      dom.lineHeight.value = '1.5';
      dom.letterSpacing.value = '0';
      dom.textColor.value = '#ffffff'; dom.textColorHex.value = '#ffffff';
      dom.bgColor.value = '#1a1a1a'; dom.bgColorHex.value = '#1a1a1a';
      dom.customText.value = 'The quick brown fox jumps over the lazy dog.';
      applyPreviewStyles(); updateContrast(); generateCode();
    });

    // Tabs
    dom.tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        dom.tabs.forEach(t => t.classList.remove('active'));
        dom.tabContents.forEach(c => {
          c.classList.remove('active', 'show');
          (c as HTMLElement).style.display = 'none';
        });
        
        tab.classList.add('active');
        dom.tabContents.forEach((c: any) => c.style.display = 'none');
        const target = document.getElementById(`tab-${tab.getAttribute('data-tab')}`);
        if (target) {
          target.style.display = 'block';
          target.classList.add('active');
        }
      });
    });

    // Copy
    dom.copyBtns.forEach(btn => {
      btn.addEventListener('click', async (e: any) => {
        const targetId = btn.getAttribute('data-target');
        const text = document.getElementById(targetId as string)?.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          const toast = document.createElement('div');
          toast.className = 'toast';
          toast.textContent = 'Code copied to clipboard!';
          dom.toastContainer.appendChild(toast);
          setTimeout(() => { toast.classList.add('hiding'); toast.addEventListener('animationend', () => toast.remove()); }, 3000);
        } catch(err) {}
      });
    });

    // Init
    renderFontList();
    updateContrast();
  </script>
</BaseLayout>
