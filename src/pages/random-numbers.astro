---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Random Number Generator" description="Generate random numbers with options for range, quantity, decimals, uniqueness, and sorting.">
  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Random Number Generator</h1>
        <p>Generate random numbers with options for range, quantity, decimals, uniqueness, and sorting.</p>
      </div>
      <a class="button" href="/">Back</a>
    </div>

    <div class="random-layout">
      <section class="panel">
        <h2 class="panel-heading">Settings</h2>
        <form id="randomForm">
          <fieldset id="form-fieldset">
            <div class="random-fields">
              <div class="field">
                <label for="minInput">Minimum</label>
                <input type="number" id="minInput" value="1" required>
              </div>
              <div class="field">
                <label for="maxInput">Maximum</label>
                <input type="number" id="maxInput" value="100" required>
              </div>
              <div class="field">
                <label for="quantityInput">Quantity</label>
                <input type="number" id="quantityInput" min="1" max="50000" value="10" required>
              </div>
            </div>

            <p class="field-note">Integers include both endpoints. Decimals can reach the minimum, but not the maximum.</p>

            <div class="random-fields">
              <div class="field">
                <span class="label-row">Options</span>
                <label class="check-row" for="floatCheck">
                  <input type="checkbox" id="floatCheck"> Allow decimals
                </label>
                <label class="check-row" for="uniqueCheck">
                  <input type="checkbox" id="uniqueCheck"> Unique numbers
                </label>
              </div>
              <div class="field" id="decimalGroup" hidden>
                <label for="decimalInput">Decimal places</label>
                <input type="number" id="decimalInput" min="0" max="15" value="2">
              </div>
              <div class="field">
                <label for="sortSelect">Sorting</label>
                <select id="sortSelect">
                  <option value="none">None</option>
                  <option value="asc">Ascending</option>
                  <option value="desc">Descending</option>
                </select>
              </div>
              <div class="field">
                <label for="separatorSelect">Separator</label>
                <select id="separatorSelect">
                  <option value=", ">Comma + space</option>
                  <option value="\n">Newline</option>
                  <option value=" ">Space</option>
                </select>
              </div>
            </div>

            <div class="field">
              <span class="label-row">Presets</span>
              <div class="preset-row">
                <button type="button" id="preset-d6">D6</button>
                <button type="button" id="preset-d20">D20</button>
                <button type="button" id="preset-lotto">Lottery 1-70</button>
                <button type="button" id="preset-powerball">Powerball</button>
                <button type="button" id="preset-dnd">D&amp;D 6x3d6</button>
              </div>
            </div>

            <button type="submit" id="generateBtn" class="primary">
              <span id="generateBtn-text">Generate Numbers</span>
            </button>
          </fieldset>
        </form>
      </section>

      <section class="panel output-panel">
        <div class="output-header">
          <h2 class="panel-heading">Generated Numbers</h2>
          <div class="button-row">
            <button type="button" id="copyBtn">Copy</button>
            <button type="button" id="clearBtn">Clear</button>
          </div>
        </div>
        <textarea id="numberOutput" readonly aria-label="Generated random numbers"></textarea>
        <div class="status-line">
          <span id="statusMessage" class="status-good">Ready</span>
          <span id="toolStats">Awaiting generation</span>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .random-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 1rem;
    align-items: start;
  }

  .panel-heading {
    margin: 0 0 1rem;
    font-size: 1rem;
  }

  #form-fieldset {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .random-fields {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 0.75rem;
  }

  input[type='number'] {
    min-height: 2.35rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--panel-muted);
    color: var(--text);
    padding: 0.45rem 0.65rem;
  }

  .field-note {
    margin: -0.35rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .check-row {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    color: var(--text);
    font-size: 0.95rem;
  }

  .preset-row,
  .button-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .output-panel {
    display: grid;
    gap: 0.75rem;
  }

  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .output-header .panel-heading {
    margin-bottom: 0;
  }

  #numberOutput {
    min-height: 245px;
    font-family: "Cascadia Mono", "Consolas", "Monaco", monospace;
  }

  .status-info {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .random-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const dom = {
      form: document.getElementById('randomForm') as HTMLFormElement,
      fieldset: document.getElementById('form-fieldset') as HTMLFieldSetElement,
      minInput: document.getElementById('minInput') as HTMLInputElement,
      maxInput: document.getElementById('maxInput') as HTMLInputElement,
      quantityInput: document.getElementById('quantityInput') as HTMLInputElement,
      floatCheck: document.getElementById('floatCheck') as HTMLInputElement,
      uniqueCheck: document.getElementById('uniqueCheck') as HTMLInputElement,
      decimalInput: document.getElementById('decimalInput') as HTMLInputElement,
      decimalGroup: document.getElementById('decimalGroup') as HTMLDivElement,
      separatorSelect: document.getElementById('separatorSelect') as HTMLSelectElement,
      sortSelect: document.getElementById('sortSelect') as HTMLSelectElement,
      numberOutput: document.getElementById('numberOutput') as HTMLTextAreaElement,
      generateBtn: document.getElementById('generateBtn') as HTMLButtonElement,
      generateBtnText: document.getElementById('generateBtn-text') as HTMLSpanElement,
      copyBtn: document.getElementById('copyBtn') as HTMLButtonElement,
      clearBtn: document.getElementById('clearBtn') as HTMLButtonElement,
      statusMessage: document.getElementById('statusMessage') as HTMLSpanElement,
      toolStats: document.getElementById('toolStats') as HTMLSpanElement,
      
      presetD6: document.getElementById('preset-d6') as HTMLButtonElement,
      presetD20: document.getElementById('preset-d20') as HTMLButtonElement,
      presetLotto: document.getElementById('preset-lotto') as HTMLButtonElement,
      presetPowerball: document.getElementById('preset-powerball') as HTMLButtonElement,
      presetDnd: document.getElementById('preset-dnd') as HTMLButtonElement,
  };

  let isProcessing = false;

  function randomUnit() {
      if (!globalThis.crypto?.getRandomValues) {
          return Math.random();
      }

      const values = new Uint32Array(1);
      globalThis.crypto.getRandomValues(values);
      return values[0] / 4294967296;
  }

  function setStatus(message: string, type: 'good' | 'bad' | 'info' = 'good') {
      dom.statusMessage.textContent = message;
      dom.statusMessage.className = type === 'bad' ? 'status-bad' : type === 'info' ? 'status-info' : 'status-good';
  }

  function toggleDecimalPlaces() {
      const show = dom.floatCheck.checked;
      dom.decimalGroup.hidden = !show;
      dom.uniqueCheck.disabled = show;
      if (show) dom.uniqueCheck.checked = false;
  }

  function applyPreset(min: number, max: number, qty: number, isFloat: boolean, isUnique: boolean, sort = 'none') {
      dom.minInput.value = min.toString();
      dom.maxInput.value = max.toString();
      dom.quantityInput.value = qty.toString();
      dom.floatCheck.checked = isFloat;
      dom.uniqueCheck.checked = isUnique;
      dom.sortSelect.value = sort;
      toggleDecimalPlaces();
      handleGenerate();
  }

  function validateInputs() {
      const min = Number(dom.minInput.value);
      const max = Number(dom.maxInput.value);
      const quantity = Number(dom.quantityInput.value);
      const decimalPlaces = Number(dom.decimalInput.value);
      
      if (!Number.isFinite(min) || !Number.isFinite(max) || !Number.isFinite(quantity)) {
          return { isValid: false, error: 'Please enter valid numbers.' };
      }
      if (min >= max) {
          return { isValid: false, error: 'Minimum must be less than maximum.' };
      }
      if (!Number.isInteger(quantity) || quantity < 1 || quantity > 50000) {
          return { isValid: false, error: 'Quantity must be a whole number from 1 to 50000.' };
      }
      if (dom.floatCheck.checked && (!Number.isInteger(decimalPlaces) || decimalPlaces < 0 || decimalPlaces > 15)) {
          return { isValid: false, error: 'Decimal places must be a whole number from 0 to 15.' };
      }
      if (dom.uniqueCheck.checked && !dom.floatCheck.checked) {
          const intMin = Math.ceil(min);
          const intMax = Math.floor(max);
          const rangeSize = intMax - intMin + 1;
          if (quantity > rangeSize) {
              return { isValid: false, error: `Cannot generate ${quantity} unique integers from a range of only ${rangeSize} numbers.` };
          }
      }
      return { isValid: true };
  }

  function fisherYatesShuffle(arr: number[]) {
      for (let i = arr.length - 1; i > 0; i--) {
          const j = Math.floor(randomUnit() * (i + 1));
          [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
  }

  function handleGenerate(e?: Event) {
      if(e) e.preventDefault();
      if (isProcessing) return;

      const validation = validateInputs();
      if (!validation.isValid) {
          dom.numberOutput.value = validation.error || 'Invalid input.';
          setStatus(validation.error || 'Invalid input.', 'bad');
          return;
      }

      isProcessing = true;
      dom.fieldset.disabled = true;
      dom.generateBtnText.textContent = 'Generating...';
      setStatus('Generating...', 'info');

      setTimeout(() => {
          const min = Number(dom.minInput.value);
          const max = Number(dom.maxInput.value);
          const quantity = Number(dom.quantityInput.value);
          const isFloat = dom.floatCheck.checked;
          const decimalPlaces = Number(dom.decimalInput.value) || 0;
          const unique = dom.uniqueCheck.checked && !isFloat;

          let numbers = [];
          
          if (unique) {
              const intMin = Math.ceil(min);
              const intMax = Math.floor(max);
              const range = Array.from({ length: intMax - intMin + 1 }, (_, i) => intMin + i);
              numbers = fisherYatesShuffle(range).slice(0, quantity);
          } else {
              for (let i = 0; i < quantity; i++) {
                  let num;
                  if (isFloat) {
                      const rand = randomUnit() * (max - min) + min;
                      num = Number(rand.toFixed(decimalPlaces));
                  } else {
                      const intMin = Math.ceil(min);
                      const intMax = Math.floor(max);
                      num = Math.floor(randomUnit() * (intMax - intMin + 1)) + intMin;
                  }
                  numbers.push(num);
              }
          }
          
          const sortType = dom.sortSelect.value;
          if (sortType === 'asc') numbers.sort((a, b) => a - b);
          else if (sortType === 'desc') numbers.sort((a, b) => b - a);
          
          const separator = dom.separatorSelect.value === '\\n' ? '\n' : dom.separatorSelect.value;
          dom.numberOutput.value = numbers.join(separator);
          setStatus(`Generated ${numbers.length} number${numbers.length === 1 ? '' : 's'}.`);
          dom.toolStats.textContent = `Range ${min} to ${max} | ${isFloat ? 'Decimals' : 'Integers'} | ${sortType === 'none' ? 'Unsorted' : sortType === 'asc' ? 'Ascending' : 'Descending'}`;
          
          isProcessing = false;
          dom.fieldset.disabled = false;
          dom.generateBtnText.textContent = 'Generate Numbers';
      }, 50);
  }

  function generatePowerball() {
      const whites = fisherYatesShuffle(Array.from({ length: 69 }, (_, i) => i + 1))
          .slice(0, 5)
          .sort((a, b) => a - b);
      const red = Math.floor(randomUnit() * 26) + 1;
      dom.numberOutput.value = `${whites.join(' ')} | Powerball: ${red}`;
      setStatus('Powerball quick pick generated.');
      dom.toolStats.textContent = 'Powerball: 5 unique white balls from 1-69, plus 1 red ball from 1-26';
  }

  function generateDndAttributes() {
      const rollD6 = () => Math.floor(randomUnit() * 6) + 1;
      const scores = Array.from({ length: 6 }, () => rollD6() + rollD6() + rollD6());
      dom.numberOutput.value = scores.join(' ');
      setStatus('D&D attributes generated.');
      dom.toolStats.textContent = 'D&D: six ability scores, each rolled as 3d6';
  }

  dom.form.addEventListener('submit', handleGenerate);
  dom.floatCheck.addEventListener('change', toggleDecimalPlaces);
  
  dom.copyBtn.addEventListener('click', () => {
      if (!dom.numberOutput.value) {
          setStatus('Nothing to copy.', 'bad');
          return;
      }
      navigator.clipboard.writeText(dom.numberOutput.value).then(
          () => setStatus('Copied to clipboard.'),
          () => setStatus('Copy failed.', 'bad')
      );
  });
  
  dom.clearBtn.addEventListener('click', () => {
      dom.numberOutput.value = '';
      dom.toolStats.textContent = 'Awaiting generation';
      setStatus('Output cleared.', 'info');
  });
  
  dom.presetD6.addEventListener('click', () => applyPreset(1, 6, 1, false, false));
  dom.presetD20.addEventListener('click', () => applyPreset(1, 20, 1, false, false));
  dom.presetLotto.addEventListener('click', () => applyPreset(1, 70, 5, false, true, 'asc'));
  dom.presetPowerball.addEventListener('click', generatePowerball);
  dom.presetDnd.addEventListener('click', generateDndAttributes);

  toggleDecimalPlaces();
</script>
