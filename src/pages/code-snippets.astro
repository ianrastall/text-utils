---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Code Snippets & Templates" description="Pick from reusable code snippets for common programming tasks.">
  <style>
    /* Target code blocks inside our specific output area */
    #mainOutput pre,
    #mainOutput code {
        color: var(--accent) !important;
        background-color: transparent !important;
    }
    
    #mainOutput {
        background-color: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        font-family: ui-monospace, Consolas, monospace;
        white-space: pre-wrap;
        min-height: 400px;
        padding: 1rem;
        overflow-y: auto;
        border-radius: 4px;
        border-top: 3px solid var(--accent);
    }
  </style>

  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Code Snippets & Templates</h1>
        <p>Pick from reusable code snippets for common programming tasks.</p>
      </div>
      <a class="button" href="/">Back</a>
    </div>

    <section class="panel d-flex flex-column" style="min-height: 600px;">
      <form id="snippetForm" onsubmit="return false;" style="display: flex; flex-direction: column; flex-grow: 1;">
        
        <div class="two-column" style="margin-bottom: 1.5rem;">
          <div class="field">
            <label for="mainCategory">Language Category</label>
            <select id="mainCategory"></select>
          </div>
          <div class="field">
            <label for="language">Programming Language</label>
            <select id="language" disabled></select>
          </div>
        </div>

        <div class="field" style="margin-bottom: 1.5rem;">
          <label for="snippetType">Snippet Type</label>
          <select id="snippetType" disabled></select>
        </div>

        <div class="field" style="flex-grow: 1; display: flex; flex-direction: column;">
          <label for="mainOutput">Code Output:</label>
          <div id="mainOutput">
            <span style="color: var(--text-muted); white-space: normal;">Select a snippet...</span>
          </div>
        </div>

        <div class="control-row" style="margin-top: 1.5rem;">
          <button type="button" id="copyBtn" class="button primary" disabled>Copy Code</button>
          <button type="button" id="clearBtn" class="button" style="color: var(--danger); border-color: var(--danger);">Clear</button>
        </div>
      </form>
      
      <div class="status-line" style="margin-top: 1.5rem;">
        <span id="status" class="status-good">Ready</span>
      </div>
    </section>
  </main>

  <script src="../scripts/code-snippets.ts"></script>
</BaseLayout>
