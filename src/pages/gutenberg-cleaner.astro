---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Project Gutenberg Cleaner" description="Clean Project Gutenberg HTML or plain text by removing boilerplate, page numbers, footnotes, and corpus noise.">
  <main class="shell pg-main">
    <header class="pg-page-header">
      <div>
        <h1>Project Gutenberg Cleaner</h1>
        <p>Clean Gutenberg HTML or plain text for ebook prep and corpus work.</p>
      </div>
      <a class="button" href="/">Back</a>
    </header>

    <section class="pg-panel pg-toolbar" aria-label="Cleaning controls">
      <div class="pg-select-row">
        <label class="pg-field">
          <span>Input</span>
          <select id="pgInputMode">
            <option value="auto">Auto detect</option>
            <option value="html">HTML</option>
            <option value="text">Plain text</option>
          </select>
        </label>
        <label class="pg-field">
          <span>Output</span>
          <select id="pgOutputMode">
            <option value="html">Cleaned HTML</option>
            <option value="text">Plain text</option>
          </select>
        </label>
      </div>

      <div class="pg-action-row">
        <button type="button" class="button primary" id="pgCleanBtn">Clean</button>
        <button type="button" class="button" id="pgSampleBtn">Example</button>
        <button type="button" class="button" id="pgPasteBtn">Paste</button>
        <button type="button" class="button" id="pgCopyBtn">Copy Output</button>
        <button type="button" class="button pg-danger" id="pgClearBtn">Clear</button>
      </div>
    </section>

    <section class="pg-grid">
      <div class="pg-panel pg-editor">
        <div class="pg-label-row">
          <label for="pgInput">Input</label>
          <span id="pgInputCount">0 chars, 0 lines</span>
        </div>
        <textarea id="pgInput" spellcheck="false" autocomplete="off" placeholder="Paste Project Gutenberg HTML or text here."></textarea>
      </div>

      <div class="pg-panel pg-editor">
        <div class="pg-label-row">
          <label for="pgOutput">Output</label>
          <span id="pgOutputCount">0 chars, 0 lines</span>
        </div>
        <textarea id="pgOutput" spellcheck="false" autocomplete="off" readonly placeholder="Cleaned output appears here."></textarea>
      </div>
    </section>

    <section class="pg-lower-grid">
      <div class="pg-panel">
        <div class="pg-panel-title">HTML Cleanup</div>
        <div class="pg-options">
          <label><input type="checkbox" id="pgOptBoilerplate" checked> Remove Gutenberg boilerplate</label>
          <label><input type="checkbox" id="pgOptPagesImages" checked> Remove page numbers and images</label>
          <label><input type="checkbox" id="pgOptToc" checked> Remove table of contents</label>
          <label><input type="checkbox" id="pgOptFootnotes" checked> Inline footnotes, then remove notes section</label>
          <label><input type="checkbox" id="pgOptAlignment"> Convert alignment classes to styles</label>
          <label><input type="checkbox" id="pgOptAttributes" checked> Strip extra attributes</label>
        </div>
      </div>

      <div class="pg-panel">
        <div class="pg-panel-title">Text Cleanup</div>
        <div class="pg-options">
          <label><input type="checkbox" id="pgOptTextMarkers" checked> Strip Gutenberg header and footer markers</label>
          <label><input type="checkbox" id="pgOptWhitespace" checked> Normalize whitespace</label>
          <label><input type="checkbox" id="pgOptUnwrap"> Unwrap hard-wrapped prose</label>
          <label><input type="checkbox" id="pgOptAggressive"> Aggressive corpus cleanup</label>
          <label><input type="checkbox" id="pgOptMarkDeleted"> Mark removed paragraphs as [deleted]</label>
        </div>
      </div>

      <div class="pg-panel">
        <div class="pg-panel-title">Summary</div>
        <div class="pg-stats">
          <div><span>Detected</span><strong id="pgStatType">-</strong></div>
          <div><span>Removed</span><strong id="pgStatRemoved">0</strong></div>
          <div><span>Footnotes</span><strong id="pgStatFootnotes">0</strong></div>
          <div><span>Output</span><strong id="pgStatOutput">-</strong></div>
        </div>
      </div>
    </section>

    <div id="pgStatus" class="pg-status" role="status" aria-live="polite">Ready</div>
  </main>

  <style>
    .pg-main {
      padding: 1rem 0 2rem;
    }

    .pg-page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .pg-page-header h1 {
      margin: 0;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      letter-spacing: 0;
    }

    .pg-page-header p {
      margin: 0.25rem 0 0;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .pg-panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.85rem;
    }

    .pg-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 0.8rem;
    }

    .pg-select-row,
    .pg-action-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .pg-field {
      display: grid;
      gap: 0.25rem;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .pg-danger {
      color: var(--danger);
      border-color: color-mix(in srgb, var(--danger) 45%, var(--border));
    }

    .pg-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }

    .pg-editor {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 0;
    }

    .pg-label-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.75rem;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .pg-label-row label {
      color: var(--muted);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .pg-label-row span {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      white-space: nowrap;
    }

    .pg-editor textarea {
      min-height: 430px;
      resize: vertical;
      border-radius: 6px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.9rem;
      line-height: 1.55;
      tab-size: 2;
    }

    .pg-lower-grid {
      display: grid;
      grid-template-columns: minmax(260px, 1fr) minmax(260px, 1fr) minmax(260px, 0.85fr);
      gap: 0.8rem;
      margin-top: 0.8rem;
    }

    .pg-panel-title {
      margin-bottom: 0.6rem;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .pg-options {
      display: grid;
      gap: 0.5rem;
    }

    .pg-options label {
      display: flex;
      align-items: flex-start;
      gap: 0.45rem;
      font-size: 0.9rem;
      cursor: pointer;
    }

    .pg-options input {
      width: 1rem;
      height: 1rem;
      margin-top: 0.18rem;
      accent-color: var(--accent);
      flex: 0 0 auto;
    }

    .pg-stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(88px, 1fr));
      gap: 0.45rem;
    }

    .pg-stats div {
      min-width: 0;
      background: var(--panel-muted);
      border-radius: 6px;
      padding: 0.55rem;
    }

    .pg-stats span {
      display: block;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .pg-stats strong {
      display: block;
      overflow: hidden;
      margin-top: 0.18rem;
      font-size: 1.05rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .pg-status {
      margin-top: 0.8rem;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .pg-status.good {
      color: var(--success);
    }

    .pg-status.bad {
      color: var(--danger);
    }

    .pg-status.warn {
      color: color-mix(in srgb, var(--danger) 60%, #f59e0b);
    }

    @media (max-width: 980px) {
      .pg-grid,
      .pg-lower-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .pg-page-header,
      .pg-toolbar,
      .pg-select-row,
      .pg-action-row {
        align-items: stretch;
        flex-direction: column;
      }
    }
  </style>

  <script>
    type PgStats = {
      removed: number;
      footnotes: number;
      detected: 'HTML' | 'Text';
      outputType: 'HTML' | 'Text';
    };

    type PgOptions = {
      boilerplate: boolean;
      pagesImages: boolean;
      toc: boolean;
      footnotes: boolean;
      alignment: boolean;
      attributes: boolean;
      textMarkers: boolean;
      whitespace: boolean;
      unwrap: boolean;
      aggressive: boolean;
      markDeleted: boolean;
    };

    const input = document.getElementById('pgInput') as HTMLTextAreaElement;
    const output = document.getElementById('pgOutput') as HTMLTextAreaElement;
    const inputMode = document.getElementById('pgInputMode') as HTMLSelectElement;
    const outputMode = document.getElementById('pgOutputMode') as HTMLSelectElement;
    const cleanBtn = document.getElementById('pgCleanBtn') as HTMLButtonElement;
    const sampleBtn = document.getElementById('pgSampleBtn') as HTMLButtonElement;
    const pasteBtn = document.getElementById('pgPasteBtn') as HTMLButtonElement;
    const copyBtn = document.getElementById('pgCopyBtn') as HTMLButtonElement;
    const clearBtn = document.getElementById('pgClearBtn') as HTMLButtonElement;
    const inputCount = document.getElementById('pgInputCount') as HTMLElement;
    const outputCount = document.getElementById('pgOutputCount') as HTMLElement;
    const statusEl = document.getElementById('pgStatus') as HTMLElement;
    const statType = document.getElementById('pgStatType') as HTMLElement;
    const statRemoved = document.getElementById('pgStatRemoved') as HTMLElement;
    const statFootnotes = document.getElementById('pgStatFootnotes') as HTMLElement;
    const statOutput = document.getElementById('pgStatOutput') as HTMLElement;

    const opts = {
      boilerplate: document.getElementById('pgOptBoilerplate') as HTMLInputElement,
      pagesImages: document.getElementById('pgOptPagesImages') as HTMLInputElement,
      toc: document.getElementById('pgOptToc') as HTMLInputElement,
      footnotes: document.getElementById('pgOptFootnotes') as HTMLInputElement,
      alignment: document.getElementById('pgOptAlignment') as HTMLInputElement,
      attributes: document.getElementById('pgOptAttributes') as HTMLInputElement,
      textMarkers: document.getElementById('pgOptTextMarkers') as HTMLInputElement,
      whitespace: document.getElementById('pgOptWhitespace') as HTMLInputElement,
      unwrap: document.getElementById('pgOptUnwrap') as HTMLInputElement,
      aggressive: document.getElementById('pgOptAggressive') as HTMLInputElement,
      markDeleted: document.getElementById('pgOptMarkDeleted') as HTMLInputElement
    };

    const startMarkers = [
      '*** START OF THE PROJECT GUTENBERG',
      '*** START OF THIS PROJECT GUTENBERG',
      'START OF THE PROJECT GUTENBERG EBOOK',
      'START OF THIS PROJECT GUTENBERG EBOOK',
      '*END*THE SMALL PRINT',
      '*END THE SMALL PRINT',
      'This etext was prepared by',
      'E-text prepared by',
      'This eBook was prepared by',
      'This Etext was prepared by',
      'Produced by',
      'Distributed Proofreading Team',
      'Project Gutenberg Online Distributed',
      'Gutenberg Distributed Proofreaders',
      'Online Distributed Proofreading Team'
    ];

    const endMarkers = [
      '*** END OF THE PROJECT GUTENBERG',
      '*** END OF THIS PROJECT GUTENBERG',
      'END OF THE PROJECT GUTENBERG EBOOK',
      'END OF THIS PROJECT GUTENBERG EBOOK',
      'End of the Project Gutenberg',
      'End of Project Gutenberg',
      'End of this Project Gutenberg',
      'END OF PROJECT GUTENBERG'
    ];

    const legaleseStarts = [
      '<<THIS ELECTRONIC VERSION',
      'Project Gutenberg License',
      'THE FULL PROJECT GUTENBERG LICENSE',
      'PLEASE READ THIS BEFORE YOU DISTRIBUTE OR USE THIS WORK',
      'START: FULL LICENSE'
    ];

    const legaleseEnds = [
      'END: FULL LICENSE'
    ];

    const sampleHtml = `<div id="pg-header">
<p>The Project Gutenberg eBook of Sample Book</p>
</div>
<h1>SAMPLE BOOK</h1>
<h2>CONTENTS</h2>
<table><tr><td>Chapter I</td><td>1</td></tr></table>
<p class="center">CHAPTER I</p>
<p>This is a paragraph of the book. <span class="pagenum">[Pg 1]</span> It includes a footnote<a href="#fn1">[1]</a>.</p>
<p class="right">A right-aligned note.</p>
<div class="footnotes"><p id="fn1">[1] This is the footnote text.</p></div>
<div id="pg-footer">End of Project Gutenberg legal text.</div>`;

    const sampleText = `The Project Gutenberg eBook of Sample Book

*** START OF THE PROJECT GUTENBERG EBOOK SAMPLE BOOK ***

CHAPTER I

This is a paragraph from the book
that has been hard-wrapped across
several lines.

[1] A footnote that can be removed by aggressive cleanup.

*** END OF THE PROJECT GUTENBERG EBOOK SAMPLE BOOK ***`;

    function currentOptions(): PgOptions {
      return {
        boilerplate: opts.boilerplate.checked,
        pagesImages: opts.pagesImages.checked,
        toc: opts.toc.checked,
        footnotes: opts.footnotes.checked,
        alignment: opts.alignment.checked,
        attributes: opts.attributes.checked,
        textMarkers: opts.textMarkers.checked,
        whitespace: opts.whitespace.checked,
        unwrap: opts.unwrap.checked,
        aggressive: opts.aggressive.checked,
        markDeleted: opts.markDeleted.checked
      };
    }

    function countLines(text: string): number {
      return text ? text.split(/\r\n|\r|\n/).length : 0;
    }

    function plural(count: number, singular: string, pluralWord = `${singular}s`): string {
      return `${count.toLocaleString()} ${count === 1 ? singular : pluralWord}`;
    }

    function updateCounts(): void {
      inputCount.textContent = `${plural(input.value.length, 'char')}, ${plural(countLines(input.value), 'line')}`;
      outputCount.textContent = `${plural(output.value.length, 'char')}, ${plural(countLines(output.value), 'line')}`;
    }

    function setStatus(message: string, kind: 'good' | 'bad' | 'warn' | '' = ''): void {
      statusEl.textContent = message;
      statusEl.className = `pg-status${kind ? ` ${kind}` : ''}`;
    }

    function updateStats(stats: PgStats | null): void {
      statType.textContent = stats?.detected ?? '-';
      statRemoved.textContent = String(stats?.removed ?? 0);
      statFootnotes.textContent = String(stats?.footnotes ?? 0);
      statOutput.textContent = stats?.outputType ?? '-';
    }

    function isLikelyHtml(text: string): boolean {
      return /<\/?[a-z][\s\S]*>/i.test(text);
    }

    function detectInput(text: string): 'HTML' | 'Text' {
      if (inputMode.value === 'html') return 'HTML';
      if (inputMode.value === 'text') return 'Text';
      return isLikelyHtml(text) ? 'HTML' : 'Text';
    }

    function normalizeLineEndings(text: string): string {
      return text.replace(/^\uFEFF/, '').replace(/\r\n?/g, '\n').replace(/\u00a0/g, ' ');
    }

    function markerMatch(line: string, markers: string[]): boolean {
      const trimmed = line.trim().toLowerCase();
      return markers.some((marker) => trimmed.startsWith(marker.toLowerCase()) || trimmed.includes(marker.toLowerCase()));
    }

    function stripGutenbergMarkers(text: string, stats: PgStats): string {
      const lines = normalizeLineEndings(text).split('\n');
      let start = 0;
      let end = lines.length;

      for (let index = 0; index < Math.min(lines.length, 500); index += 1) {
        if (markerMatch(lines[index], startMarkers)) {
          start = index + 1;
          break;
        }
      }

      for (let index = start; index < lines.length; index += 1) {
        if (markerMatch(lines[index], endMarkers)) {
          end = index;
          break;
        }
      }

      let ignoreLegalese = false;
      const kept: string[] = [];
      for (const line of lines.slice(start, end)) {
        if (markerMatch(line, legaleseStarts)) {
          ignoreLegalese = true;
          stats.removed += 1;
          continue;
        }
        if (markerMatch(line, legaleseEnds)) {
          ignoreLegalese = false;
          stats.removed += 1;
          continue;
        }
        if (!ignoreLegalese) kept.push(line);
      }

      stats.removed += start + (lines.length - end);
      return kept.join('\n').trim();
    }

    function normalizeWhitespace(text: string): string {
      return normalizeLineEndings(text)
        .split('\n')
        .map((line) => line.replace(/[ \t]+$/g, ''))
        .join('\n')
        .replace(/\n{4,}/g, '\n\n\n')
        .trim();
    }

    function unwrapProse(text: string): string {
      return text.split(/\n{2,}/).map((paragraph) => {
        const lines = paragraph.split('\n').map((line) => line.trim()).filter(Boolean);
        if (lines.length <= 1) return paragraph.trim();
        const looksLikeList = lines.some((line) => /^(\s*[-*]|\s*\d+[.)])\s+/.test(line));
        const looksLikeTable = lines.filter((line) => /\t|\s{3,}/.test(line)).length >= Math.ceil(lines.length * 0.6);
        return looksLikeList || looksLikeTable ? lines.join('\n') : lines.join(' ');
      }).join('\n\n');
    }

    function tokenCount(text: string): number {
      const matches = text.trim().match(/\b[\w'-]+\b/g);
      return matches ? matches.length : 0;
    }

    function nonTextRatio(text: string): number {
      const compact = text.replace(/\s+/g, '');
      if (!compact) return 0;
      const noisy = compact.split('').filter((char) => /[A-Z0-9!"#$%&'()*+,./:;<=>?@[\\\]^_`{|}~-]/.test(char)).length;
      return noisy / compact.length;
    }

    function isAggressiveRemoval(paragraph: string): boolean {
      const text = paragraph.trim();
      const lower = text.toLowerCase();
      const words = tokenCount(text);

      if (!text) return true;
      if (/\.(png|jpe?g|gif|webp|svg)\b|picture:|image:/i.test(text)) return true;
      if (/^[{\[][^}\]]+[}\]]/.test(text)) return true;
      if (lower.includes('footnote') && text.replace(/\s+/g, '').length < 80) return true;
      if (/[\w.-]+@[\w.-]+\.\w+/.test(text) && text.length < 180) return true;
      if (/(copyright|\d+\s+copies|printed in|original title)/i.test(text) && text.length < 500) return true;
      if (lower.includes('project gutenberg') && text.length < 320) return true;
      if (/^[%_<>*]/.test(text)) return true;
      if (words > 0 && words < 5 && !/["'].*["']|:$/.test(text)) return true;
      if (nonTextRatio(text) > 0.62 && text.length < 220) return true;

      const lines = text.split('\n');
      const tabularLines = lines.filter((line) => /\t/.test(line) || /\s{3,}/.test(line));
      if (lines.length > 2 && tabularLines.length >= Math.ceil(lines.length * 0.6)) return true;
      if ((text.match(/[=*]/g) || []).length > 5 && text.length < 300) return true;

      return false;
    }

    function aggressiveTextCleanup(text: string, options: PgOptions, stats: PgStats): string {
      const paragraphs = text.split(/\n{2,}/);
      const cleaned = paragraphs.flatMap((paragraph) => {
        if (isAggressiveRemoval(paragraph)) {
          stats.removed += 1;
          return options.markDeleted ? ['[deleted]'] : [];
        }
        return [paragraph.trim()];
      });
      return cleaned.join('\n\n').trim();
    }

    function cleanPlainText(raw: string, options: PgOptions, stats: PgStats): string {
      let text = normalizeLineEndings(raw);
      if (options.textMarkers) text = stripGutenbergMarkers(text, stats);
      if (options.aggressive) text = aggressiveTextCleanup(text, options, stats);
      if (options.unwrap) text = unwrapProse(text);
      if (options.whitespace) text = normalizeWhitespace(text);
      return text;
    }

    function removeNode(node: Element | ChildNode, stats: PgStats): void {
      node.parentNode?.removeChild(node);
      stats.removed += 1;
    }

    function removeAll(nodes: Iterable<Element>, stats: PgStats): void {
      Array.from(nodes).forEach((node) => removeNode(node, stats));
    }

    function removeComments(doc: Document, stats: PgStats): void {
      const walker = doc.createTreeWalker(doc.body || doc, NodeFilter.SHOW_COMMENT);
      const comments: Comment[] = [];
      let current = walker.nextNode();
      while (current) {
        comments.push(current as Comment);
        current = walker.nextNode();
      }
      comments.forEach((comment) => removeNode(comment, stats));
    }

    function removeTableOfContents(doc: Document, stats: PgStats): void {
      removeAll(doc.querySelectorAll('#contents, #toc, .toc, nav[role="doc-toc"]'), stats);

      const headings = Array.from(doc.querySelectorAll('h1,h2,h3,h4,h5,h6'));
      headings.forEach((heading) => {
        if (!/\b(contents|table of contents)\b/i.test(heading.textContent || '')) return;
        let next = heading.nextElementSibling;
        while (next && next.textContent?.trim() === '') next = next.nextElementSibling;
        if (next && /^(TABLE|UL|OL|NAV)$/i.test(next.tagName)) {
          removeNode(next, stats);
          removeNode(heading, stats);
        }
      });
    }

    function transformFootnotes(doc: Document, stats: PgStats): void {
      const containers = Array.from(doc.querySelectorAll('[id*="footnote" i], [class*="footnote" i], [id*="endnote" i], [class*="endnote" i]'));
      const map = new Map<string, string>();

      containers.forEach((container) => {
        const candidates = Array.from(container.querySelectorAll('[id]'));
        if (container.id) candidates.unshift(container);
        candidates.forEach((item) => {
          const id = item.getAttribute('id');
          if (!id || !/^(fn|footnote|note|endnote)/i.test(id)) return;
          const text = (item.textContent || '').replace(/\s+/g, ' ').replace(/^\s*\[?\d+\]?\s*\.?\s*/, '').trim();
          if (text) map.set(`#${CSS.escape(id)}`, text);
        });
      });

      Array.from(doc.querySelectorAll('a[href^="#"]')).forEach((link) => {
        const href = link.getAttribute('href') || '';
        const rawId = href.slice(1);
        const text = map.get(`#${CSS.escape(rawId)}`);
        if (!text || !/^(fn|footnote|note|endnote)/i.test(rawId)) return;
        const span = doc.createElement('span');
        span.className = 'inline-footnote';
        span.setAttribute('role', 'note');
        span.textContent = ` [${text}]`;
        link.parentNode?.replaceChild(span, link);
        stats.footnotes += 1;
      });

      containers.forEach((container) => {
        if (container.parentNode) removeNode(container, stats);
      });
    }

    function convertAlignment(doc: Document): void {
      const alignments: Record<string, string> = {
        center: 'center',
        centered: 'center',
        right: 'right',
        left: 'left'
      };

      Object.entries(alignments).forEach(([className, align]) => {
        Array.from(doc.getElementsByClassName(className)).forEach((element) => {
          const existing = element.getAttribute('style') || '';
          element.setAttribute('style', `${existing} text-align: ${align};`.trim());
        });
      });

      Array.from(doc.querySelectorAll('h1,h2,h3,h4,h5,h6')).forEach((heading) => {
        const existing = heading.getAttribute('style') || '';
        heading.setAttribute('style', `${existing} text-align: center;`.trim());
      });
    }

    function sanitizeAttributes(doc: Document, options: PgOptions): void {
      const allowed = new Set(['href', 'alt', 'role']);
      if (options.alignment) allowed.add('style');

      Array.from(doc.querySelectorAll('*')).forEach((element) => {
        Array.from(element.attributes).forEach((attr) => {
          const name = attr.name.toLowerCase();
          const value = attr.value.trim().toLowerCase();

          if (name.startsWith('on')) {
            element.removeAttribute(attr.name);
            return;
          }

          if ((name === 'href' || name === 'src') && /^(javascript|data):/.test(value)) {
            element.removeAttribute(attr.name);
            return;
          }

          if (options.attributes && !allowed.has(name)) {
            element.removeAttribute(attr.name);
          }
        });
      });
    }

    function cleanHtml(raw: string, options: PgOptions, stats: PgStats): string {
      const doc = new DOMParser().parseFromString(raw, 'text/html');
      if (!doc.body) throw new Error('Could not parse HTML.');

      removeComments(doc, stats);
      removeAll(doc.querySelectorAll('script, style, noscript, iframe, object, embed'), stats);

      if (options.boilerplate) {
        removeAll(doc.querySelectorAll('#pg-header, #pg-footer, .pg-boilerplate, .x-ebookmaker-drop'), stats);
      }

      if (options.toc) removeTableOfContents(doc, stats);
      if (options.footnotes) transformFootnotes(doc, stats);
      if (options.alignment) convertAlignment(doc);

      if (options.pagesImages) {
        removeAll(doc.querySelectorAll('span.pagenum, .pagenum, [class*="pagenum" i], img, picture, figure'), stats);
      }

      sanitizeAttributes(doc, options);
      return doc.body.innerHTML.trim();
    }

    function htmlToText(html: string): string {
      let text = html
        .replace(/<br\s*\/?>/gi, '\n')
        .replace(/<\/(p|div|section|article|blockquote|h[1-6]|li|tr|table)>/gi, '\n\n')
        .replace(/<li\b[^>]*>/gi, '- ');
      const doc = new DOMParser().parseFromString(text, 'text/html');
      return normalizeWhitespace(doc.body?.textContent || '');
    }

    function cleanInput(): void {
      const raw = input.value;
      if (!raw.trim()) {
        output.value = '';
        updateCounts();
        updateStats(null);
        setStatus('Nothing to clean.', 'warn');
        return;
      }

      try {
        const detected = detectInput(raw);
        const options = currentOptions();
        const stats: PgStats = {
          removed: 0,
          footnotes: 0,
          detected,
          outputType: outputMode.value === 'html' && detected === 'HTML' ? 'HTML' : 'Text'
        };

        let cleaned = '';
        if (detected === 'HTML') {
          const cleanedHtml = cleanHtml(raw, options, stats);
          cleaned = outputMode.value === 'html'
            ? cleanedHtml
            : cleanPlainText(htmlToText(cleanedHtml), options, stats);
        } else {
          cleaned = cleanPlainText(raw, options, stats);
          if (outputMode.value === 'html') {
            stats.outputType = 'Text';
            setStatus('Plain text input cannot produce structured HTML, so output is text.', 'warn');
          }
        }

        output.value = cleaned;
        updateCounts();
        updateStats(stats);
        if (!(detected === 'Text' && outputMode.value === 'html')) {
          setStatus(`Cleaned ${stats.detected.toLowerCase()} input. Removed ${plural(stats.removed, 'item')}.`, 'good');
        }
      } catch (error) {
        const err = error as Error;
        output.value = '';
        updateCounts();
        updateStats(null);
        setStatus(err.message, 'bad');
      }
    }

    cleanBtn.addEventListener('click', cleanInput);

    sampleBtn.addEventListener('click', () => {
      const shouldUseText = inputMode.value === 'text' || (inputMode.value === 'auto' && outputMode.value === 'text' && opts.unwrap.checked);
      input.value = shouldUseText ? sampleText : sampleHtml;
      output.value = '';
      updateCounts();
      updateStats(null);
      setStatus('Example loaded.', 'good');
      input.focus();
    });

    pasteBtn.addEventListener('click', async () => {
      try {
        input.value = await navigator.clipboard.readText();
        output.value = '';
        updateCounts();
        updateStats(null);
        setStatus('Pasted from clipboard.', 'good');
      } catch {
        setStatus('Paste failed. Check clipboard permissions.', 'bad');
      }
    });

    copyBtn.addEventListener('click', async () => {
      if (!output.value) {
        setStatus('Nothing to copy.', 'warn');
        return;
      }
      try {
        await navigator.clipboard.writeText(output.value);
        setStatus('Output copied.', 'good');
      } catch {
        setStatus('Copy failed. Check clipboard permissions.', 'bad');
      }
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      output.value = '';
      updateCounts();
      updateStats(null);
      setStatus('Ready', '');
      input.focus();
    });

    input.addEventListener('input', updateCounts);

    input.addEventListener('keydown', (event: KeyboardEvent) => {
      if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
        event.preventDefault();
        cleanInput();
      }
    });

    updateCounts();
    updateStats(null);
  </script>
</BaseLayout>
