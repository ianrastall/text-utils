---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Markdown Previewer" description="Edit and preview Markdown in real-time.">
  <!-- Load marked.js from CDN -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  
  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Markdown Previewer</h1>
        <p>Edit and preview Markdown in real-time.</p>
      </div>
      <a class="button" href="/">Back</a>
    </div>
    
    <section class="panel" style="display: flex; flex-direction: column; flex: 1;">
      <div class="control-row">
        <button id="copy-html-btn" class="button primary" type="button">Copy HTML</button>
        <button id="copy-md-btn" class="button" type="button">Copy Markdown</button>
        <button id="clear-btn" class="button" type="button" style="color: var(--danger); border-color: var(--danger);">Clear</button>
      </div>
      
      <div class="two-column" style="flex: 1; margin-top: 1rem; min-height: 500px;">
        <div class="field" style="height: 100%; display: flex; flex-direction: column;">
          <label for="md-editor">Markdown</label>
          <textarea id="md-editor" placeholder="Type markdown here..." style="flex: 1; font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: 1rem; line-height: 1.5; resize: none;" set:text={`# Hello Markdown

This is a live previewer for **Markdown**. 

## Features
- Real-time rendering
- Supports standard Markdown syntax
- Easy to use

### Code Example
\`\`\`javascript
function greet() {
  console.log("Hello, world!");
}
\`\`\`

> Blockquotes and other elements work out of the box.

[Visit Astro](https://astro.build)`}></textarea>
        </div>
        
        <div class="field" style="height: 100%; display: flex; flex-direction: column;">
          <label>Preview</label>
          <div id="md-preview" class="preview-pane"></div>
        </div>
      </div>
      
      <div class="status-line">
        <span id="status" class="status-good">Ready</span>
        <span id="stats"></span>
      </div>
    </section>
  </main>
  
  <style>
    .preview-pane {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.5rem;
      overflow-y: auto;
      color: var(--text);
    }
    
    /* Basic markdown styles for the preview */
    .preview-pane h1, .preview-pane h2, .preview-pane h3 {
      margin-top: 0;
      margin-bottom: 1rem;
      color: var(--text-heading);
    }
    .preview-pane h1 { border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
    .preview-pane p { margin-bottom: 1rem; line-height: 1.6; }
    .preview-pane a { color: var(--accent); text-decoration: none; }
    .preview-pane a:hover { text-decoration: underline; }
    .preview-pane code {
      background: var(--panel-muted);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      font-family: ui-monospace, monospace;
      font-size: 0.9em;
    }
    .preview-pane pre {
      background: var(--panel-muted);
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      margin-bottom: 1rem;
    }
    .preview-pane pre code {
      background: none;
      padding: 0;
    }
    .preview-pane blockquote {
      border-left: 4px solid var(--border);
      margin: 0 0 1rem 0;
      padding-left: 1rem;
      color: var(--text-muted);
    }
    .preview-pane ul, .preview-pane ol {
      margin-bottom: 1rem;
      padding-left: 2rem;
    }
    .preview-pane img {
      max-width: 100%;
    }
  </style>
  
  <script>
    const editor = document.getElementById('md-editor') as HTMLTextAreaElement;
    const preview = document.getElementById('md-preview') as HTMLDivElement;
    const copyHtmlBtn = document.getElementById('copy-html-btn') as HTMLButtonElement;
    const copyMdBtn = document.getElementById('copy-md-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const status = document.getElementById('status') as HTMLSpanElement;
    const stats = document.getElementById('stats') as HTMLSpanElement;

    function renderMarkdown() {
      const text = editor.value;
      if (!text) {
        preview.innerHTML = '';
        stats.textContent = '0 characters, 0 words';
        return;
      }
      
      try {
        // @ts-ignore - marked is loaded globally via CDN
        if (typeof marked !== 'undefined') {
          // @ts-ignore
          preview.innerHTML = marked.parse(text);
          const wordCount = text.trim().split(/\s+/).filter(w => w.length > 0).length;
          stats.textContent = `${text.length} characters, ${wordCount} words`;
        } else {
          preview.innerHTML = '<p style="color:var(--danger)">Error: Markdown parser not loaded.</p>';
        }
      } catch (err: any) {
        console.error("Markdown parsing error:", err);
        status.textContent = "Parsing error";
        status.style.color = "var(--danger)";
      }
    }

    editor.addEventListener('input', renderMarkdown);
    
    // Initial render
    window.addEventListener('DOMContentLoaded', () => {
      // Small delay to ensure marked is loaded from CDN
      setTimeout(renderMarkdown, 100);
    });
    
    copyHtmlBtn.addEventListener('click', async () => {
      if (!preview.innerHTML) return;
      await navigator.clipboard.writeText(preview.innerHTML);
      showStatus('HTML Copied to clipboard!');
    });
    
    copyMdBtn.addEventListener('click', async () => {
      if (!editor.value) return;
      await navigator.clipboard.writeText(editor.value);
      showStatus('Markdown Copied to clipboard!');
    });
    
    clearBtn.addEventListener('click', () => {
      editor.value = '';
      renderMarkdown();
      editor.focus();
    });
    
    function showStatus(msg: string) {
      const original = status.textContent;
      const originalColor = status.style.color;
      status.textContent = msg;
      status.style.color = 'var(--success)';
      window.setTimeout(() => {
        status.textContent = original;
        status.style.color = originalColor;
      }, 2000);
    }
  </script>
</BaseLayout>
