---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="JSON & CSV Converter" description="JSON and CSV conversion has moved into the unified JSON Tools page.">
  <Fragment slot="head">
    <meta http-equiv="refresh" content="0; url=/json-tools.html" />
    <link rel="canonical" href="/json-tools.html" />
  </Fragment>

  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>JSON &amp; CSV Converter</h1>
        <p>This converter has moved into JSON Tools.</p>
      </div>
      <a class="button primary" href="/json-tools.html">Open JSON Tools</a>
    </div>
  </main>

  <script is:inline>
    window.location.replace('/json-tools.html');
  </script>
</BaseLayout>
