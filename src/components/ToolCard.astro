---
import type { ToolMeta } from '../data/tools';
import { categoryHref, categoryLabels } from '../data/tools';

interface Props {
  tool: ToolMeta;
}

const { tool } = Astro.props;
const categoryLabel = categoryLabels[tool.category];
---
<article class="tool-card">
  <a class="tag tag-link" href={categoryHref(tool.category)} aria-label={`View ${categoryLabel} tools`}>{categoryLabel}</a>
  <a class="tool-card-link" href={tool.href}>
    <h2>{tool.name}</h2>
    <p>{tool.description}</p>
  </a>
</article>
