---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Fast, private text tools that run in your browser.' } = Astro.props;
const pageTitle = title === 'Text Utilities' ? title : `${title} - Text Utilities`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <slot name="head" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('text-utils-theme');
        const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.theme = stored || (prefersDark ? 'dark' : 'light');
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-mark">T</span>
          <span>Text Utilities</span>
        </a>
        <div class="header-actions">
          <label class="color-picker-wrap" title="Accent color">
            <span class="color-swatch" id="color-swatch"></span>
            <input type="color" id="accent-picker" />
          </label>
          <a class="button" href="https://github.com/ianrastall/text-utils" rel="noreferrer" target="_blank">GitHub</a>
          <button id="theme-toggle" type="button">Theme</button>
        </div>
      </header>
    </div>
    <slot />
    <div class="shell">
      <footer class="site-footer">
        <p>Text Utilities runs locally in your browser. Built by Ian Rastall.</p>
      </footer>
    </div>
    <script>
      // Theme toggle
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle?.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('text-utils-theme', next);
        applyAccent(localStorage.getItem('text-utils-accent') || null);
      });

      // Accent colour picker
      function hexToHsl(hex: string): [number, number, number] {
        let r = parseInt(hex.slice(1, 3), 16) / 255;
        let g = parseInt(hex.slice(3, 5), 16) / 255;
        let b = parseInt(hex.slice(5, 7), 16) / 255;
        const max = Math.max(r, g, b), min = Math.min(r, g, b);
        let h = 0, s = 0;
        const l = (max + min) / 2;
        if (max !== min) {
          const d = max - min;
          s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
          switch (max) {
            case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
            case g: h = ((b - r) / d + 2) / 6; break;
            case b: h = ((r - g) / d + 4) / 6; break;
          }
        }
        return [Math.round(h * 360), Math.round(s * 100), Math.round(l * 100)];
      }

      function hslToHex(h: number, s: number, l: number): string {
        s /= 100; l /= 100;
        const k = (n: number) => (n + h / 30) % 12;
        const a = s * Math.min(l, 1 - l);
        const f = (n: number) => l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
        return '#' + [f(0), f(8), f(4)].map(x => Math.round(x * 255).toString(16).padStart(2, '0')).join('');
      }

      function applyAccent(hex: string | null) {
        const root = document.documentElement;
        const isDark = root.dataset.theme === 'dark';
        if (!hex) {
          root.style.removeProperty('--accent');
          root.style.removeProperty('--accent-strong');
          return;
        }
        const [h, s] = hexToHsl(hex);
        // Light: moderately saturated mid-tone; Dark: bright teal-style
        const accent      = isDark ? hslToHex(h, Math.min(s + 10, 100), 65) : hslToHex(h, Math.min(s, 90), 40);
        const accentStrong = isDark ? hslToHex(h, Math.min(s + 5, 100), 75) : hslToHex(h, Math.min(s, 90), 32);
        root.style.setProperty('--accent', accent);
        root.style.setProperty('--accent-strong', accentStrong);
        const swatch = document.getElementById('color-swatch') as HTMLElement | null;
        if (swatch) swatch.style.background = accent;
      }

      function initAccent() {
        const stored = localStorage.getItem('text-utils-accent');
        const picker = document.getElementById('accent-picker') as HTMLInputElement | null;
        if (stored && picker) picker.value = stored;
        applyAccent(stored);
        // sync swatch on load
        const swatch = document.getElementById('color-swatch') as HTMLElement | null;
        if (swatch && stored) swatch.style.background = stored;
      }

      initAccent();

      document.getElementById('accent-picker')?.addEventListener('input', (e) => {
        const hex = (e.target as HTMLInputElement).value;
        localStorage.setItem('text-utils-accent', hex);
        applyAccent(hex);
      });

      // Reset on double-click
      document.getElementById('accent-picker')?.addEventListener('dblclick', () => {
        localStorage.removeItem('text-utils-accent');
        applyAccent(null);
        const swatch = document.getElementById('color-swatch') as HTMLElement | null;
        if (swatch) swatch.style.background = '';
      });
    </script>
  </body>
</html>
